@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="app-shell">
    <header class="topbar">
        <div class="topbar-inner">
            <a href="" class="brand">
                <span class="brand-icon">D</span>
                Dictorium
                <span class="brand-demo">demo</span>
            </a>
            <div class="topbar-tagline">
                Интерактивная визуализация структур данных на C++ / WebAssembly
            </div>
            <div class="topbar-right">
                <a href="https://github.com/UterSt" target="_blank" class="gh-link">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                    </svg>
                    GitHub
                </a>
            </div>
        </div>
    </header>

    <nav class="main-nav" aria-label="Основная навигация">
        <a href="" class="nav-link @(IsActive("") ? "active" : "")"
           title="Главная страница с обзором всех структур">Обзор</a>
        <a href="compare" class="nav-link @(IsActive("compare") ? "active" : "")"
           title="Сравнение характеристик нескольких структур">Сравнение</a>

        <span class="nav-sep">|</span>
        <span class="nav-label" title="Запустить алгоритм прямо в браузере">▶ LIVE:</span>

        <a href="demo/linear"
           class="nav-link nav-demo @(IsActive("demo/linear") ? "active" : "")"
           title="LinearDictionary — простой последовательный словарь">
            Linear
        </a>
        <a href="demo/lp"
           class="nav-link nav-demo @(IsActive("demo/lp") ? "active" : "")"
           title="LinearProbingDictionary — открытая адресация">
            LinProbing
        </a>
        <a href="demo/chaining"
           class="nav-link nav-demo @(IsActive("demo/chaining") ? "active" : "")"
           title="ChainingDictionary — метод цепочек (Открытое хеширование)">
            Chaining
        </a>
        <a href="demo/perfecthash"
           class="nav-link nav-demo @(IsActive("demo/perfecthash") ? "active" : "")"
           title="PerfectHashDictionary — совершенное хеширование O(1)">
            PerfectHash
        </a>
        <a href="demo/avl"
           class="nav-link nav-demo @(IsActive("demo/avl") ? "active" : "")"
           title="AvlDictionary — сбалансированное AVL-дерево">
            AVL Tree
        </a>
        <a href="demo/cuckoo"
           class="nav-link nav-demo @(IsActive("demo/cuckoo") ? "active" : "")"
           title="CuckooDictionary — кукушкино хеширование O(1)">
            Cuckoo
        </a>
    </nav>

    @if (IsOnDemoPage())
    {
        <div class="demo-banner">
            <span class="demo-banner-dot">●</span>
            Интерактивный режим — библиотека Dictorium запущена в WebAssembly.
            Вводите ключи и значения, нажимайте кнопки и наблюдайте за структурой.
        </div>
    }

    <main class="main-content">
        @Body
    </main>

    <footer class="app-footer">
        <strong>Dictorium Demo</strong> &nbsp;&middot;&nbsp;
        C++ → WebAssembly (Emscripten) &nbsp;&middot;&nbsp;
        <span class="footer-structs">Linear · LinearProbing · Chaining · PerfectHash · AVL · Cuckoo</span>
        &nbsp;&middot;&nbsp;
        <a href="https://github.com/UterSt" target="_blank" class="footer-link">GitHub</a>
    </footer>
</div>

@code {
    private bool IsActive(string href)
    {
        var current = Nav.ToBaseRelativePath(Nav.Uri);
        if (href == "") return current is "" or "/";
        return current.StartsWith(href);
    }

    private bool IsOnDemoPage()
    {
        var current = Nav.ToBaseRelativePath(Nav.Uri);
        return current.StartsWith("demo/");
    }
}
