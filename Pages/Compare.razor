    private async Task DoContains()
    {
        if (_busy || string.IsNullOrWhiteSpace(_keyInput)) return;
        _busy = true;
        var key = _keyInput.Trim();
        SetGlobalStatus($"ContainsKey(\"{key}\")...", "", "▶");
        await Task.WhenAll(_selected.Where(s => s != null).Select(s => s!.Slug).Select(slug => ContainsAsync(slug, key)));
        SetGlobalStatus($"ContainsKey(\"{key}\") выполнено", "status-ok", "✓");
        _busy = false; StateHasChanged();
    }

    private async Task ContainsAsync(string slug, string key)
    {
        var st = GetState(slug);
        await EnsureInitAsync(slug);
        bool found = await SlugContainsAsync(slug, st, key);
        st.LastResult = found ? $"ContainsKey(\"{key}\") → true" : $"ContainsKey(\"{key}\") → false";
        st.ResultCls  = found ? "status-ok" : "status-err";
        AddLog(st, st.LastResult, found ? "log-ok" : "log-miss");
        await RefreshAsync(slug);
    }

