private void RenderDhTable(RenderTreeBuilder b, SS st)
{ int q=0;var t=st.DhTable;if(t==null){b.AddMarkupContent(q++,"<div style='padding:8px;color:var(--text-3);font-size:11px;'>Ожидание...</div>");return;}
  for(int i=0;i<t.Length;i++)
  { var slot=t[i];bool cur=st.ProbeCursor==i,home=i==st.ProbeHome&&st.ProbeHome>=0;
    string cls=st.SlotAnimCls.TryGetValue(i,out var ac)?ac:slot.State switch{DhS.Occupied=>"lp-occ",DhS.Deleted=>"lp-del",_=>"lp-empty"};
    b.OpenElement(q++,"div");b.AddAttribute(q++,"class",$"cmp-lp-slot {cls}{(home?" lp-home":"")}");
    if(cur){b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-arrow");b.AddContent(q++,"▶");b.CloseElement();}
    b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-idx");b.AddContent(q++,$"[{i}]");b.CloseElement();
    b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-dot");b.AddContent(q++,slot.State==DhS.Occupied?"●":slot.State==DhS.Deleted?"✕":"○");b.CloseElement();
    if(slot.State==DhS.Occupied){b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-key");b.AddContent(q++,Trunc(slot.Key,9));b.CloseElement();b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-sep");b.AddContent(q++,"→");b.CloseElement();b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-val");b.AddContent(q++,Trunc(slot.Value,9));b.CloseElement();
      if(slot.HomeSlot>=0&&slot.HomeSlot!=i){b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-hbadge");b.AddContent(q++,$"h₁={slot.HomeSlot}");b.CloseElement();}}
    else if(slot.State==DhS.Deleted){b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-sep");b.AddContent(q++,"tombstone");b.CloseElement();}
    b.CloseElement(); }
  if(st.ProbePath.Count>0) AppendTrailSimple(b,ref q,st.ProbePath,st.ProbeHit);
  AppendLB(b,ref q,st.LoadFactor,st.Count,st.Capacity); }

