    sb.Append($"<line x1='{F(rx+4)}' y1='{F(n.Y+1)}' x2='{F(rx+116)}' y2='{F(n.Y+1)}' stroke='#ccc' stroke-width='0.5'/>");
    sb.Append($"<text x='{F(n.X)}' y='{F(n.Y+13)}' text-anchor='middle' font-family='monospace' font-size='10' fill='#886600'>p={n.Prio}</text>"); }
  sb.Append("</svg></div>"); return sb.ToString(); }

private const string EMPTY_SVG="<div style='padding:14px;color:var(--text-3);font-style:italic;font-family:var(--font-ui);font-size:11px;'>Дерево пустое</div>";

// ─── Skip List ───────────────────────────────────────────────────────────────
private const double SlHX=40,SlSW=34,SlNW=94,SlNH=40,SlLG=10,SlNG=16,SlTP=86;
private static readonly Random SlRng=new();
private static int SlGenLevel(int max){int l=1;while(SlRng.NextDouble()<.5&&l<Math.Max(max,8))l++;return l;}
private static double SlLY(int lv,double H)=>H-SlNH-lv*(SlNH+SlLG);
private static string SLT(double x,double y,string t,int sz=12,string fill="#dde4ee",string anchor="middle",string weight="normal")
{ return $"<text x=\"{F(x)}\" y=\"{F(y)}\" font-size=\"{sz}\" fill=\"{fill}\" text-anchor=\"{anchor}\" font-family=\"monospace\" font-weight=\"{weight}\">{System.Net.WebUtility.HtmlEncode(t)}</text>"; }

private void BuildSlSvg(SS st)
{ var items=st.SlItems??new(); if(items.Count==0){st.SlSvg="<div style='padding:12px;color:var(--text-3);font-family:var(--font-ui);font-size:11px;font-style:italic;'>Список пуст</div>";return;}
  var sorted=items.OrderBy(i=>i.Key,StringComparer.Ordinal).ToList();
  int visL=sorted.Count>0?Math.Max(1,sorted.Max(i=>st.SlNodeLevels.TryGetValue(i.Key,out var h)?h:1)):1;
  visL=Math.Min(visL,8);if(st.MaxLevel>0)visL=Math.Max(visL,Math.Min(st.MaxLevel,8));
  double startX=SlHX+SlSW+SlNG,W=startX+sorted.Count*(SlNW+SlNG)+SlTP+SlSW+10,H=visL*(SlNH+SlLG)+50;
  double sentH=visL*SlNH+(visL-1)*SlLG,sentY=SlLY(visL-1,H);
  var sb=new System.Text.StringBuilder();
  sb.Append($"<div class='cmp-sl-wrap'><svg viewBox=\"0 0 {F(W)} {F(H)}\" style=\"width:100%;min-width:{Math.Max(400,(int)W)}px;height:auto;display:block;\" xmlns=\"http://www.w3.org/2000/svg\">");
  sb.Append("<defs><marker id=\"sla\" markerWidth=\"7\" markerHeight=\"7\" refX=\"6\" refY=\"3.5\" orient=\"auto\"><polygon points=\"0 0,7 3.5,0 7\" fill=\"#8899aa\" opacity=\"0.7\"/></marker>");
  sb.Append("<marker id=\"slx\" markerWidth=\"8\" markerHeight=\"8\" refX=\"7\" refY=\"4\" orient=\"auto\"><polygon points=\"0 0,8 4,0 8\" fill=\"#339966\" opacity=\"0.8\"/></marker>");
  sb.Append("<marker id=\"sls\" markerWidth=\"8\" markerHeight=\"8\" refX=\"7\" refY=\"4\" orient=\"auto\"><polygon points=\"0 0,8 4,0 8\" fill=\"#cc8800\"/></marker></defs>");
  sb.Append($"<rect x=\"0\" y=\"0\" width=\"{F(W)}\" height=\"{F(H)}\" fill=\"#fff\"/>");
  for(int lv=visL-1;lv>=0;lv--){double cy=SlLY(lv,H)+SlNH/2+5;sb.Append(SLT(24,cy,$"L{lv}",11,"#8899aa"));}
  for(int lv=visL-1;lv>=0;lv--){double ly=SlLY(lv,H)+SlNH/2;sb.Append($"<line x1=\"{F(SlHX)}\" y1=\"{F(ly)}\" x2=\"{F(W-SlTP)}\" y2=\"{F(ly)}\" stroke=\"rgba(100,120,150,0.15)\" stroke-width=\"1\" stroke-dasharray=\"5 5\"/>");}
  var nx=new Dictionary<string,double>();for(int i=0;i<sorted.Count;i++)nx[sorted[i].Key]=startX+i*(SlNW+SlNG);
  for(int lv=0;lv<visL;lv++)
  { bool ex=lv>0;double ay=SlLY(lv,H)+SlNH/2;double fromX=SlHX+SlSW;
    foreach(var item in sorted)
    { int h=st.SlNodeLevels.TryGetValue(item.Key,out var lh)?lh:1;if(h<=lv)continue;
      double toX=nx[item.Key];bool scan=st.AnimPath.Contains(item.Key);
      string mid=scan?"sls":(ex?"slx":"sla");string stk=scan?"#cc8800":(ex?"#339966":"#8899aa");double sw=scan?2.2:(ex?2:1.4);
      sb.Append($"<line x1=\"{F(fromX)}\" y1=\"{F(ay)}\" x2=\"{F(toX-5)}\" y2=\"{F(ay)}\" stroke=\"{stk}\" stroke-width=\"{F(sw)}\" opacity=\"{(scan?1.0:0.6)}\" marker-end=\"url(#{mid})\"/>");fromX=toX+SlNW;}
    double tailX=W-SlTP;string ta=ex?"slx":"sla";string ts=ex?"#339966":"#8899aa";
    sb.Append($"<line x1=\"{F(fromX)}\" y1=\"{F(ay)}\" x2=\"{F(tailX-5)}\" y2=\"{F(ay)}\" stroke=\"{ts}\" stroke-width=\"{(ex?"1.4":"1.0")}\" opacity=\"0.35\" marker-end=\"url(#{ta})\"/>");}
  sb.Append($"<rect x=\"{F(SlHX)}\" y=\"{F(sentY)}\" width=\"{F(SlSW)}\" height=\"{F(sentH)}\" rx=\"4\" fill=\"#f0eef8\" stroke=\"#9977bb\" stroke-width=\"1.2\"/>");
  sb.Append(SLT(SlHX+SlSW/2,sentY+sentH/2+5,"\u2212\u221e",14,"#6644aa"));
  double tailSX=W-SlTP;
  sb.Append($"<rect x=\"{F(tailSX)}\" y=\"{F(sentY)}\" width=\"{F(SlSW)}\" height=\"{F(sentH)}\" rx=\"4\" fill=\"#f0eef8\" stroke=\"#9977bb\" stroke-width=\"1.2\"/>");
  sb.Append(SLT(tailSX+SlSW/2,sentY+sentH/2+5,"+\u221e",14,"#6644aa"));
  foreach(var item in sorted)
  { double x=nx[item.Key];int height=st.SlNodeLevels.TryGetValue(item.Key,out var nh)?Math.Min(nh,visL):1;
    AState ns=item.Key==st.AnimHit?AState.Hit:item.Key==st.AnimMiss?AState.Miss:st.AnimPath.Contains(item.Key)?AState.Scanning:AState.Normal;
    if(height>1){double topY=SlLY(height-1,H),btY=SlLY(0,H)+SlNH;sb.Append($"<line x1=\"{F(x+SlNW/2)}\" y1=\"{F(topY)}\" x2=\"{F(x+SlNW/2)}\" y2=\"{F(btY)}\" stroke=\"rgba(50,130,80,0.35)\" stroke-width=\"2\" stroke-dasharray=\"3 2\"/>");}
    for(int lv=0;lv<height;lv++)
    { double by=SlLY(lv,H);bool ex=lv>0;
      (string f,string stk,double sw)=ns switch{AState.Hit=>("#ddf4dd","#008800",2),AState.Miss=>("#f4dddd","#880000",2),AState.Scanning=>("#fffacc","#998800",2),_ when ex=>("#eef7ee","#339966",1.4),_=>("#eef2f7","#8899aa",1)};
      sb.Append($"<rect x=\"{F(x)}\" y=\"{F(by)}\" width=\"{F(SlNW)}\" height=\"{F(SlNH)}\" rx=\"5\" fill=\"{f}\" stroke=\"{stk}\" stroke-width=\"{F(sw)}\"/>");
      if(lv==0){sb.Append(SLT(x+SlNW/2,by+15,Trunc(item.Key,9),11,"#111","middle","600"));sb.Append(SLT(x+SlNW/2,by+SlNH-7,Trunc(item.Value,9),9,"#556677"));}
      else{sb.Append(SLT(x+SlNW/2,by+SlNH/2+4,Trunc(item.Key,9),10,"#226644","middle","600"));sb.Append(SLT(x+SlNW-4,by+9,$"L{lv}",7,"#339966","end"));} } }
  sb.Append("</svg></div>");st.SlSvg=sb.ToString(); }

