private RenderFragment RenderViz(string slug, SS st) => slug switch
{ "open-hashing"=>(RenderFragment)(b=>RenderChaining(b,st)), "linear-probing"=>(b=>RenderLpTable(b,st)), "quadratic-probing"=>(b=>RenderQpTable(b,st)),
  "double-hashing"=>(b=>RenderDhTable(b,st)), "robin-hood-hashing"=>(b=>RenderRhTable(b,st)), "cuckoo-hashing"=>(b=>RenderCuckoo(b,st)),
  "perfect-hashing"=>(b=>RenderPh(b,st)),
  "avl-tree"     =>(b=>b.AddMarkupContent(0,string.IsNullOrEmpty(st.TreeSvg)?EMPTY_SVG:st.TreeSvg)),
  "red-black-tree"=>(b=>b.AddMarkupContent(0,string.IsNullOrEmpty(st.TreeSvg)?EMPTY_SVG:st.TreeSvg)),
  "skip-list"    =>(b=>b.AddMarkupContent(0,string.IsNullOrEmpty(st.SlSvg)?"<div style='padding:12px;color:var(--text-3);font-family:var(--font-ui);font-size:11px;font-style:italic;'>Список пуст</div>":st.SlSvg)),
  "cartesian-tree"=>(b=>b.AddMarkupContent(0,string.IsNullOrEmpty(st.TreeSvg)?EMPTY_SVG:st.TreeSvg)),
  _=>builder=>{} };

private void RenderChaining(RenderTreeBuilder b, SS st)
{ int q=0;
  if(st.ChainBuckets==null||st.ChainBuckets.Count==0){b.AddMarkupContent(q++,"<div style='padding:8px;color:var(--text-3);font-size:11px;font-style:italic;'>Таблица пуста</div>");return;}
  foreach(var bkt in st.ChainBuckets)
  { bool probing=st.ChainProbeBucket==bkt.Slot;
    b.OpenElement(q++,"div");b.AddAttribute(q++,"class",$"cmp-chain-bucket{(probing?" cmp-chain-bkt-active":"")}");
    b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-chain-idx");b.AddContent(q++,$"[{bkt.Slot}]");b.CloseElement();
    b.OpenElement(q++,"div");b.AddAttribute(q++,"class","cmp-chain-items");
    if(bkt.Chain.Count==0){b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-chain-empty");b.AddContent(q++,"—");b.CloseElement();}
    else foreach(var item in bkt.Chain)
    { string cls=probing&&item.Key==st.ChainProbeKey?"cmp-chain-item ch-hit":probing?"cmp-chain-item ch-probe":"cmp-chain-item";
      b.OpenElement(q++,"span");b.AddAttribute(q++,"class",cls);b.AddContent(q++,$"{Trunc(item.Key,8)}→{Trunc(item.Value,8)}");b.CloseElement(); }
    b.CloseElement();b.CloseElement(); }
  AppendLB(b,ref q,st.LoadFactor,st.Count,st.Capacity); }

private void RenderLpTable(RenderTreeBuilder b, SS st)
{ int q=0; var snap=st.LpSnap;
  if(snap==null||snap.Capacity==0){b.AddMarkupContent(q++,"<div style='padding:8px;color:var(--text-3);font-size:11px;'>Ожидание...</div>");return;}
  foreach(var slot in snap.Slots)
  { bool cur=st.ProbeCursor==slot.Index,home=slot.Index==st.ProbeHome&&st.ProbeHome>=0;
    string cls=st.SlotAnimCls.TryGetValue(slot.Index,out var ac)?ac:slot.State switch{LpSlotState.Occupied=>"lp-occ",LpSlotState.Deleted=>"lp-del",_=>"lp-empty"};
    b.OpenElement(q++,"div");b.AddAttribute(q++,"class",$"cmp-lp-slot {cls}{(home?" lp-home":"")}");
    if(cur){b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-arrow");b.AddContent(q++,"▶");b.CloseElement();}
    b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-idx");b.AddContent(q++,$"[{slot.Index}]");b.CloseElement();
    b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-dot");b.AddContent(q++,slot.State==LpSlotState.Occupied?"●":slot.State==LpSlotState.Deleted?"✕":"○");b.CloseElement();
    if(slot.State==LpSlotState.Occupied)
    { if(home){b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-home-badge");b.AddContent(q++,"home");b.CloseElement();}
      b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-key");b.AddContent(q++,Trunc(slot.Key,9));b.CloseElement();
      b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-sep");b.AddContent(q++,"→");b.CloseElement();
      b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-val");b.AddContent(q++,Trunc(slot.Value,9));b.CloseElement();
      if(slot.HomeSlot>=0&&slot.HomeSlot!=slot.Index){b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-hbadge");b.AddContent(q++,$"h={slot.HomeSlot}");b.CloseElement();} }
    else if(slot.State==LpSlotState.Deleted){b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-sep");b.AddContent(q++,"tombstone");b.CloseElement();}
    b.CloseElement(); }
  if(st.ProbePath.Count>0) AppendTrail(b,ref q,st.ProbePath,st.ProbeHit,snap,null);
  AppendLB(b,ref q,snap.LoadFactor,snap.Count,snap.Capacity); }

