@page "/compare"
@using Microsoft.AspNetCore.Components.Rendering
@inject DictoriumJsService Dtr
@inject DataStructureService DS
@inject NavigationManager Nav

<PageTitle>Сравнение структур — Dictorium Demo</PageTitle>

<div class="compare-page-wrap">

    <h1 class="compare-h1">Сравнение структур данных</h1>
    <p class="compare-sub">Выберите до 3 структур — операции выполняются синхронно во всех выбранных.</p>

    <!-- ═══ Selector ═══ -->
    <div class="selector-area">
        @for (int i = 0; i < 3; i++)
        {
            int idx = i;
            var selected = _selected[idx];

            <div class="selector-slot">
                <div class="slot-lbl">Структура @(idx + 1)</div>

                @if (selected == null)
                {
                    <div class="slot-empty">— выберите из списка ниже —</div>
                }
                else
                {
                    var cat = DS.GetCategoryForStructure(selected.Slug);
                    <div class="slot-filled">
                        <span class="slot-cat-icon">@cat?.Icon</span>
                        <div class="slot-info">
                            <strong>@selected.NameRu</strong>
                            <small>@cat?.NameRu</small>
                        </div>
                        <button class="slot-rm" @onclick="() => RemoveSlot(idx)">&#10005;</button>
                    </div>
                }

                <div class="slot-drop">
                    @foreach (var cat in DS.GetAllCategories())
                    {
                        var supportedStructures = cat.Structures
                            .Where(s => s.Slug != "b-tree" && s.Slug != "b-plus-tree")
                            .ToList();
                        if (!supportedStructures.Any()) continue;

                        <div class="dd-grp">
                            <div class="dd-grp-lbl" style="color: @cat.AccentColor">@cat.Icon &nbsp;@cat.NameRu</div>
                            @foreach (var s in supportedStructures)
                            {
                                bool alreadyPicked = _selected.Any(x => x?.Slug == s.Slug);
                                <button class="dd-item @(selected?.Slug == s.Slug ? "selected" : "") @(alreadyPicked && selected?.Slug != s.Slug ? "disabled" : "")"
                                        disabled="@(alreadyPicked && selected?.Slug != s.Slug)"
                                        @onclick="() => Select(idx, s)">
                                    <span class="dd-num" style="color: @cat.AccentColor">#@s.IssueNumber</span>
                                    <span>@s.NameRu</span>
                                    <span class="dd-en">@s.Name</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @{
        var active = _selected.Where(s => s != null).Select(s => s!).ToList();
    }

    @if (active.Count >= 2)
    {
        <!-- ═══ WASM status ═══ -->
        <div class="cmp-wasm-bar">
            @if (!_wasmReady)
            {
                <span class="cmp-wasm-loading">○ Загрузка WebAssembly модуля Dictorium...</span>
            }
            else
            {
                <span class="cmp-wasm-ok">● WASM готов</span>
                <span class="cmp-wasm-sep">·</span>
                <span class="cmp-wasm-note">Все операции выполняются синхронно в реальных экземплярах структур</span>
            }
        </div>

        @if (_wasmReady)
        {
            <!-- ═══ Sync controls — sticky at top ═══ -->
            <div class="cmp-ctrl-bar">
                <div class="cmp-ctrl-inputs">
                    <div class="cmp-ctrl-field">
                        <label class="cmp-ctrl-lbl">Ключ</label>
                        <input class="search-input cmp-input" @bind="_keyInput" @bind:event="oninput"
                               placeholder="apple" disabled="@_busy" />
                    </div>
                    <div class="cmp-ctrl-field">
                        <label class="cmp-ctrl-lbl">Значение</label>
                        <input class="search-input cmp-input" @bind="_valInput" @bind:event="oninput"
                               placeholder="яблоко" disabled="@_busy" />
                    </div>
                </div>
                <div class="cmp-ctrl-ops">
                    <button class="btn-op btn-search" @onclick="DoContains"
                            disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput))">
                        ▶ ContainsKey
                    </button>
                    <button class="btn-op btn-add" @onclick="DoAdd"
                            disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput) || string.IsNullOrWhiteSpace(_valInput))">
                        + Add
                    </button>
                    <button class="btn-op btn-add" @onclick="DoInsertOrAssign"
                            disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput) || string.IsNullOrWhiteSpace(_valInput))">
                        ± InsertOrAssign
                    </button>
                    <button class="btn-op btn-remove" @onclick="DoRemove"
                            disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput))">
                        − Remove
                    </button>
                    <button class="btn-op btn-clear" @onclick="DoClear" disabled="@_busy">
                        ⊘ Clear
                    </button>
                    <button class="btn-op" @onclick="LoadSample" disabled="@_busy">
                        Загрузить пример
                    </button>
                </div>
                @if (!string.IsNullOrEmpty(_globalStatus))
                {
                    <div class="cmp-global-status @_globalStatusCls">
                        <strong>@_globalStatusIcon</strong>&nbsp; @_globalStatus
                    </div>
                }
            </div>

            <!-- ═══ Live visualization panels — RIGHT BELOW controls ═══ -->
            <div class="cmp-viz-grid cmp-viz-cols-@active.Count">
                @foreach (var s in active)
                {
                    var cat = DS.GetCategoryForStructure(s.Slug);
                    var st  = GetState(s.Slug);
                    <div class="cmp-viz-panel">
                        <div class="cmp-viz-panel-head" style="border-top: 3px solid @(cat?.AccentColor ?? "#4ade80")">
                            <span class="cmp-viz-panel-icon">@cat?.Icon</span>
                            <div>
                                <div class="cmp-viz-panel-name">@s.NameRu</div>
                                <div class="cmp-viz-panel-eng">@s.Name</div>
                            </div>
                            <div class="cmp-viz-panel-meta">
                                <span class="cmp-meta-item">n=@st.Count</span>
                                @if (st.Capacity > 0)
                                {
                                    <span class="cmp-meta-item">cap=@st.Capacity</span>
                                    <span class="cmp-meta-item">α=@st.LoadFactor.ToString("F2")</span>
                                }
                                @if (st.Height > 0)
                                {
                                    <span class="cmp-meta-item">h=@st.Height</span>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(st.LastResult))
                        {
                            <div class="cmp-viz-result @st.ResultCls">@st.LastResult</div>
                        }

                        <div class="cmp-viz-body">
                            @RenderViz(s.Slug, st)
                        </div>

                        <div class="cmp-viz-log">
                            @foreach (var line in st.Log.TakeLast(6))
                            {
                                <div class="log-line @line.Cls">@line.Text</div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- ═══ Complexity table — below visualizations ═══ -->
            <div class="table-wrap" style="margin-top: 12px;">
                <table class="comp-table">
                    <thead>
                        <tr>
                            <th class="lbl-th">Параметр</th>
                            @foreach (var s in active)
                            {
                                var cat = DS.GetCategoryForStructure(s.Slug);
                                <th>
                                    <div class="ct-head-inner">
                                        <span>@cat?.Icon</span>
                                        <strong>@s.NameRu</strong>
                                        <small>@s.Name</small>
                                    </div>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="section-tr"><td colspan="@(active.Count + 1)">Временная сложность</td></tr>
                        <tr>
                            <td class="lbl-td">&#128269; Поиск</td>
                            @foreach (var s in active)
                            {
                                <td><span class="@ComplexityColorCls(s.TimeComplexitySearch)">@s.TimeComplexitySearch</span></td>
                            }
                        </tr>
                        <tr>
                            <td class="lbl-td">&#43; Вставка</td>
                            @foreach (var s in active)
                            {
                                <td><span class="@ComplexityColorCls(s.TimeComplexityInsert)">@s.TimeComplexityInsert</span></td>
                            }
                        </tr>
                        <tr>
                            <td class="lbl-td">&#10005; Удаление</td>
                            @foreach (var s in active)
                            {
                                <td><span class="@ComplexityColorCls(s.TimeComplexityDelete)">@s.TimeComplexityDelete</span></td>
                            }
                        </tr>
                        <tr>
                            <td class="lbl-td">&#128190; Память</td>
                            @foreach (var s in active)
                            {
                                <td><span class="ct-mono">@s.SpaceComplexity</span></td>
                            }
                        </tr>
                        <tr class="section-tr"><td colspan="@(active.Count + 1)">Достоинства и недостатки</td></tr>
                        <tr>
                            <td class="lbl-td">&#43; Плюсы</td>
                            @foreach (var s in active)
                            {
                                <td>@foreach (var pro in s.Pros) { <span class="ct-item pro">@pro</span> }</td>
                            }
                        </tr>
                        <tr>
                            <td class="lbl-td">&#8722; Минусы</td>
                            @foreach (var s in active)
                            {
                                <td>@foreach (var con in s.Cons) { <span class="ct-item con">@con</span> }</td>
                            }
                        </tr>
                        <tr class="section-tr"><td colspan="@(active.Count + 1)">Применение</td></tr>
                        <tr>
                            <td class="lbl-td">&#9702; Use cases</td>
                            @foreach (var s in active)
                            {
                                <td>@foreach (var uc in s.UseCases) { <span class="ct-item use">@uc</span> }</td>
                            }
                        </tr>
                    </tbody>
                </table>
            </div>
        }
    }
    else if (active.Count == 1)
    {
        <p class="comp-hint">Выберите ещё минимум одну структуру для сравнения.</p>
    }
    else
    {
        <p class="comp-hint">Выберите 2–3 структуры, чтобы начать сравнение.</p>
    }

</div>

<style>
.cmp-wasm-bar {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    padding: 5px 12px;
    font-family: var(--font-ui);
    font-size: 11px;
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 8px;
}
.cmp-wasm-loading { color: var(--acc-r); }
.cmp-wasm-ok      { color: var(--acc-g); font-weight: bold; }
.cmp-wasm-sep     { color: var(--border); }
.cmp-wasm-note    { color: var(--text-3); }

.cmp-ctrl-bar {
    background: var(--bg-alt);
    border: 1px solid var(--border-dk);
    padding: 8px 12px;
    margin-bottom: 8px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: flex-end;
    position: sticky;
    top: 0;
    z-index: 10;
}
.cmp-ctrl-inputs { display: flex; gap: 8px; flex-wrap: wrap; }
.cmp-ctrl-field  { display: flex; flex-direction: column; gap: 3px; }
.cmp-ctrl-lbl    { font-family: var(--font-ui); font-size: 10px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.4px; }
.cmp-input       { min-width: 130px; margin-bottom: 0 !important; }
.cmp-ctrl-ops    { display: flex; flex-wrap: wrap; gap: 4px; align-items: flex-end; }

.cmp-global-status {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 2px 8px;
    border: 1px solid var(--border);
    align-self: flex-end;
}
.cmp-global-status.status-ok  { background: #ddffdd; color: #004400; border-color: #88cc88; }
.cmp-global-status.status-err { background: #ffdddd; color: #440000; border-color: #cc8888; }

.ct-mono-o1   { font-family: var(--font-mono); font-size: 13px; font-weight: bold; color: #00aa44; }
.ct-mono-olog { font-family: var(--font-mono); font-size: 13px; font-weight: bold; color: #0066cc; }
.ct-mono-on   { font-family: var(--font-mono); font-size: 13px; font-weight: bold; color: #cc4400; }
.ct-mono-na   { font-family: var(--font-mono); font-size: 11px; color: var(--text-3); font-style: italic; }

.cmp-viz-grid { display: grid; gap: 8px; margin-top: 0; }
.cmp-viz-cols-2 { grid-template-columns: 1fr 1fr; }
.cmp-viz-cols-3 { grid-template-columns: 1fr 1fr 1fr; }

.cmp-viz-panel {
    border: 1px solid var(--border-dk);
    background: var(--bg);
    display: flex;
    flex-direction: column;
    min-width: 0;
}

.cmp-viz-panel-head {
    background: var(--bg-nav);
    color: #ffffff;
    padding: 6px 10px;
    display: flex;
    align-items: center;
    gap: 8px;
}
.cmp-viz-panel-icon { font-size: 18px; }
.cmp-viz-panel-name { font-family: var(--font-serif); font-size: 13px; font-weight: bold; line-height: 1.2; }
.cmp-viz-panel-eng  { font-family: var(--font-mono); font-size: 10px; color: #aaccee; }
.cmp-viz-panel-meta { margin-left: auto; display: flex; flex-direction: column; align-items: flex-end; gap: 1px; }
.cmp-meta-item      { font-family: var(--font-mono); font-size: 10px; color: #aaccee; white-space: nowrap; }

.cmp-viz-result {
    padding: 3px 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    border-bottom: 1px solid var(--border);
}
.cmp-viz-result.status-ok   { background: #ddffdd; color: #004400; }
.cmp-viz-result.status-err  { background: #ffdddd; color: #440000; }
.cmp-viz-result.status-warn { background: #fff8cc; color: #554400; }

.cmp-viz-body {
    padding: 6px 8px;
    flex: 1;
    overflow-x: auto;
    min-height: 120px;
    max-height: 420px;
    overflow-y: auto;
}

.cmp-viz-log {
    border-top: 1px solid var(--border);
    padding: 3px 8px;
    max-height: 72px;
    overflow-y: auto;
    background: var(--bg-alt);
}

/* ── Hash table slot rows ── */
.cmp-lp-slot {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 2px 4px;
    margin-bottom: 1px;
    font-family: var(--font-mono);
    font-size: 10px;
    border: 1px solid transparent;
    border-radius: 2px;
}
.cmp-lp-slot.lp-empty { color: var(--text-3); background: var(--bg-alt); border-color: var(--border); }
.cmp-lp-slot.lp-occ   { color: var(--text);   background: #f0f8f0;       border-color: #88cc88; }
.cmp-lp-slot.lp-del   { color: var(--text-3); background: #f8f0f0;       border-color: #cc8888; text-decoration: line-through; }
.cmp-lp-idx  { min-width: 22px; color: var(--text-3); }
.cmp-lp-dot  { font-size: 8px; min-width: 10px; }
.cmp-lp-key  { font-weight: bold; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 70px; }
.cmp-lp-sep  { color: var(--text-3); }
.cmp-lp-val  { color: var(--acc-b); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 70px; }
.cmp-lp-home { margin-left: auto; font-size: 9px; color: #0044cc; border-left: 2px solid #0044cc; padding-left: 3px; }

/* ── Cuckoo ── */
.cmp-ck-table  { margin-bottom: 6px; }
.cmp-ck-label  { font-family: var(--font-ui); font-size: 9px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.4px; padding: 2px 0; }
.cmp-ck-slots  { display: flex; flex-wrap: wrap; gap: 2px; }
.cmp-ck-slot   { border: 1px solid #8899cc; background: #eef2ff; min-width: 62px; padding: 2px 4px; font-family: var(--font-mono); font-size: 9px; text-align: center; }
.cmp-ck-slot.ck-t2    { background: #f2eeff; border-color: #9966bb; }
.cmp-ck-slot.ck-empty { background: var(--bg-alt); border-color: var(--border); }
.cmp-ck-slot.ck-found { background: #e0ffe8; border-color: var(--acc-g); }
.cmp-ck-idx { font-size: 8px; color: var(--text-3); }
.cmp-ck-key { font-weight: bold; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 58px; }
.cmp-ck-val { color: var(--acc-b); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 58px; }

/* ── Chaining ── */
.cmp-chain-bucket { display: flex; align-items: flex-start; gap: 4px; margin-bottom: 2px; font-family: var(--font-mono); font-size: 10px; }
.cmp-chain-idx   { min-width: 22px; color: var(--text-3); }
.cmp-chain-items { display: flex; flex-wrap: wrap; gap: 2px; }
.cmp-chain-item  { background: #eef8ee; border: 1px solid #88cc88; padding: 1px 4px; font-size: 9px; white-space: nowrap; }
.cmp-chain-empty { color: var(--text-3); font-style: italic; font-size: 9px; }

/* ── Linear dict ── */
.cmp-linear-item { display: flex; align-items: center; gap: 4px; padding: 2px 4px; margin-bottom: 1px; font-family: var(--font-mono); font-size: 10px; border: 1px solid var(--border); background: var(--bg-alt); }
.cmp-linear-idx  { color: var(--text-3); min-width: 18px; font-size: 9px; }

/* ── Perfect hash ── */
.cmp-ph-item { display: flex; gap: 4px; padding: 2px 4px; font-family: var(--font-mono); font-size: 10px; border: 1px solid var(--border); margin-bottom: 1px; background: var(--bg-alt); }
.cmp-ph-note { font-size: 9px; color: var(--text-3); font-style: italic; padding: 4px; font-family: var(--font-ui); }

/* ── Tree / SVG wrappers ── */
.cmp-tree-wrap { overflow-x: auto; background: #ffffff; }
.cmp-sl-wrap   { overflow-x: auto; background: #ffffff; }

/* ── Load bar ── */
.cmp-load-bar-wrap { display: flex; align-items: center; gap: 4px; margin-top: 3px; padding: 0 2px; }
.cmp-load-bar-bg   { flex: 1; height: 6px; background: var(--border); border: 1px solid var(--border-dk); }
.cmp-load-bar-fill { height: 100%; background: var(--acc-g); transition: width .3s; }
.cmp-load-bar-fill.warn { background: #e5a000; }
.cmp-load-bar-fill.crit { background: var(--acc-r); }
.cmp-load-val { font-family: var(--font-mono); font-size: 9px; color: var(--text-3); white-space: nowrap; }

/* ── RBT legend inside panel ── */
.cmp-rbt-legend { display: flex; gap: 10px; flex-wrap: wrap; padding: 3px 2px 4px; font-family: var(--font-ui); font-size: 9px; color: var(--text-3); }
.cmp-rbt-swatch { display: inline-block; width: 18px; height: 10px; border: 1px solid; vertical-align: middle; margin-right: 3px; }
.cmp-rbt-swatch-b { background: #e8edf5; border-color: #445566; }
.cmp-rbt-swatch-r { background: #fde8e8; border-color: #cc3333; }
</style>

@code {
    // ══ Query params ═════════════════════════════════════════════════════════
    [SupplyParameterFromQuery(Name = "a")] public string? PreloadA { get; set; }

    // ══ Selection ════════════════════════════════════════════════════════════
    private DataStructureInfo?[] _selected = new DataStructureInfo?[3];

    // ══ WASM ═════════════════════════════════════════════════════════════════
    private bool _wasmReady;

    // ══ Inputs ═══════════════════════════════════════════════════════════════
    private string _keyInput = "";
    private string _valInput = "";
    private bool   _busy;

    // ══ Global status ═════════════════════════════════════════════════════════
    private string _globalStatus     = "";
    private string _globalStatusCls  = "";
    private string _globalStatusIcon = "";

    // ══ Per-structure state ═══════════════════════════════════════════════════

    private record LogLine(string Text, string Cls);

    private class StructureState
    {
        public int  WasmHandle  = -1;
        public bool Initialized;

        public int    Count;
        public int    Capacity;
        public int    Height;
        public int    BlackHeight;
        public double LoadFactor;
        public int    MaxLevel;

        public string LastResult = "";
        public string ResultCls  = "";

        public readonly List<LogLine> Log = new();

        // Hash table snapshots
        public LpSnapshot?  LpSnap;
        public QpSnapshot?  QpSnap;
        public DhSlot[]?    DhTable;
        public RhSlot[]?    RhTable;
        public List<ChainBucket>? ChainBuckets;

        // Cuckoo — proper T1/T2
        public List<CkSlotForViz> CkT1 = new();
        public List<CkSlotForViz> CkT2 = new();

        // Perfect hash
        public List<DictItem>? PhItems;
        public int  PhHandle = -1;
        public bool PhBuilt;

        // Trees — SVG
        public string TreeSvg = "";

        // Skip list — SVG
        public List<DictItem>?            SlItems;
        public Dictionary<string, int>    SlNodeLevels = new();
        public string                     SlSvg = "";
    }

    private class CkSlotForViz
    {
        public int    Idx;
        public string Key   = "";
        public string Value = "";
        public bool   Occupied => !string.IsNullOrEmpty(Key);
    }

    // DH slot (C# simulation)
    private enum DhState { Empty, Occupied, Deleted }
    private class DhSlot
    {
        public DhState State    = DhState.Empty;
        public string  Key      = "";
        public string  Value    = "";
        public int     HomeSlot = -1;
    }

    // RH slot (C# simulation)
    private enum RhState { Empty, Occupied }
    private class RhSlot
    {
        public RhState State    = RhState.Empty;
        public string  Key      = "";
        public string  Value    = "";
        public int     HomeSlot = -1;
        public int     Psl;
    }

    // RBT (C# implementation)
    private enum RbColor { Red, Black }
    private class RbtNode
    {
        public string   Key   = "";
        public string   Value = "";
        public RbColor  Color = RbColor.Black;
        public RbtNode? Left, Right, Parent;
    }

    private Dictionary<string, StructureState> _states   = new();
    private Dictionary<string, RbtNode?>       _rbtRoots = new();
    private Dictionary<string, RbtNode>        _rbtNils  = new();

    private StructureState GetState(string slug)
    {
        if (!_states.TryGetValue(slug, out var st)) { st = new StructureState(); _states[slug] = st; }
        return st;
    }

    private RbtNode GetNil(string slug) =>
        _rbtNils.TryGetValue(slug, out var n) ? n : new RbtNode { Color = RbColor.Black };

    // ══ Lifecycle ═════════════════════════════════════════════════════════════

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(PreloadA))
            _selected[0] = DS.GetStructure(PreloadA);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Dtr.InitAsync();
        _wasmReady = true;
        foreach (var s in _selected.Where(s => s != null).Select(s => s!))
            await EnsureInitAsync(s.Slug);
        StateHasChanged();
    }

    // ══ Selection ════════════════════════════════════════════════════════════

    private async Task Select(int slot, DataStructureInfo s)
    {
        if (_selected[slot]?.Slug == s.Slug) { _selected[slot] = null; return; }
        _selected[slot] = s;
        if (_wasmReady) await EnsureInitAsync(s.Slug);
        StateHasChanged();
    }

    private void RemoveSlot(int idx) { _selected[idx] = null; StateHasChanged(); }

    // ══ Init ═════════════════════════════════════════════════════════════════

    private async Task EnsureInitAsync(string slug)
    {
        var st = GetState(slug);
        if (st.Initialized) return;
        switch (slug)
        {
            case "open-hashing":       st.WasmHandle = await Dtr.ChainingCreateAsync(); break;
            case "linear-probing":     st.WasmHandle = await Dtr.LpCreateAsync();       break;
            case "quadratic-probing":  st.WasmHandle = await Dtr.QpCreateAsync();       break;
            case "double-hashing":     st.DhTable = NewDhTable(11);                     break;
            case "robin-hood-hashing": st.RhTable = NewRhTable(11);                     break;
            case "cuckoo-hashing":     st.WasmHandle = await Dtr.CuckooCreateAsync();   break;
            case "perfect-hashing":    st.PhItems = new(); st.PhBuilt = false;           break;
            case "avl-tree":           st.WasmHandle = await Dtr.AvlCreateAsync();       break;
            case "red-black-tree":
                _rbtRoots[slug] = null;
                _rbtNils[slug]  = new RbtNode { Color = RbColor.Black };
                break;
            case "skip-list":          st.WasmHandle = await Dtr.SlCreateAsync();       break;
            case "cartesian-tree":     st.WasmHandle = await Dtr.TreapCreateAsync();    break;
        }
        st.Initialized = true;
        await RefreshAsync(slug);
    }

