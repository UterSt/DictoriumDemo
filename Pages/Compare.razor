private void RenderCuckoo(RenderTreeBuilder b, SS st)
{ int q=0;
  if(st.CkT1.Count==0){b.AddMarkupContent(q++,"<div style='padding:8px;color:var(--text-3);font-size:11px;font-style:italic;'>Таблица пуста</div>");return;}
  void RCT(string label,List<CkVizSlot> slots,string t)
  { b.OpenElement(q++,"div");b.AddAttribute(q++,"class","cmp-ck-table");
    b.OpenElement(q++,"div");b.AddAttribute(q++,"class","cmp-ck-label");b.AddContent(q++,label);b.CloseElement();
    b.OpenElement(q++,"div");b.AddAttribute(q++,"class","cmp-ck-slots");
    foreach(var s in slots)
    { bool isP=st.CkProbe.HasValue&&st.CkProbe.Value.T==t&&st.CkProbe.Value.I==s.Idx;
      bool isR=st.CkResult.HasValue&&st.CkResult.Value.T==t&&st.CkResult.Value.I==s.Idx;
      string cls=$"cmp-ck-slot{(t=="t2"?" ck-t2":"")} {(isR?"ck-found":isP?"ck-probe":s.Occupied?"":"ck-empty")}".Trim();
      b.OpenElement(q++,"div");b.AddAttribute(q++,"class",cls);
      b.OpenElement(q++,"div");b.AddAttribute(q++,"class","cmp-ck-idx");b.AddContent(q++,$"[{s.Idx}]");b.CloseElement();
      if(s.Occupied){b.OpenElement(q++,"div");b.AddAttribute(q++,"class","cmp-ck-key");b.AddContent(q++,Trunc(s.Key,7));b.CloseElement();b.OpenElement(q++,"div");b.AddAttribute(q++,"class","cmp-ck-val");b.AddContent(q++,Trunc(s.Value,7));b.CloseElement();}
      b.CloseElement();}
    b.CloseElement();b.CloseElement();}
  RCT("T1 — h₁(key) = fnv1a·A mod cap",st.CkT1,"t1");
  RCT("T2 — h₂(key) = fnv1a·B mod cap",st.CkT2,"t2");
  AppendLB(b,ref q,st.LoadFactor,st.Count,st.Capacity); }

private void RenderPh(RenderTreeBuilder b, SS st)
{ int q=0;
  if(!st.PhBuilt||(st.PhItems?.Count??0)==0){b.AddMarkupContent(q++,"<div class='cmp-ph-note'>Добавьте элементы — таблица пересоберётся автоматически.</div>");return;}
  b.AddMarkupContent(q++,$"<div class='cmp-ph-note'>FKS perfect hash · {st.PhItems!.Count} ключей · O(1) worst-case</div>");
  foreach(var item in st.PhItems!)
  { bool hit=item.Key==st.PhHitKey;
    b.OpenElement(q++,"div");b.AddAttribute(q++,"class",$"cmp-ph-item{(hit?" ph-hit":"")}");
    b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-key");b.AddContent(q++,Trunc(item.Key,12));b.CloseElement();
    b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-sep");b.AddContent(q++,"→");b.CloseElement();
    b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-lp-val");b.AddContent(q++,Trunc(item.Value,12));b.CloseElement();
    b.CloseElement();} }

private static void AppendTrail(RenderTreeBuilder b,ref int q,List<int> path,bool hit,LpSnapshot? lp,QpSnapshot? qp)
{ if(path.Count==0)return;
  b.OpenElement(q++,"div");b.AddAttribute(q++,"class","cmp-probe-trail");
  for(int i=0;i<path.Count;i++){int si=path[i];
    if(i>0){b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-trail-arrow");b.AddContent(q++,"→");b.CloseElement();}
    var s=lp?.Slots.FirstOrDefault(x=>x.Index==si)??qp?.Slots.FirstOrDefault(x=>x.Index==si);
    string tc=i==0?"cmp-trail-home":i==path.Count-1&&hit?"cmp-trail-hit":s?.State==LpSlotState.Deleted?"cmp-trail-del":"cmp-trail-col";
    b.OpenElement(q++,"span");b.AddAttribute(q++,"class",tc);b.AddContent(q++,$"[{si}]");b.CloseElement();}
  b.CloseElement();}

private static void AppendTrailSimple(RenderTreeBuilder b,ref int q,List<int> path,bool hit)
{ if(path.Count==0)return;
  b.OpenElement(q++,"div");b.AddAttribute(q++,"class","cmp-probe-trail");
  for(int i=0;i<path.Count;i++){
    if(i>0){b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-trail-arrow");b.AddContent(q++,"→");b.CloseElement();}
    string tc=i==0?"cmp-trail-home":i==path.Count-1&&hit?"cmp-trail-hit":"cmp-trail-col";
    b.OpenElement(q++,"span");b.AddAttribute(q++,"class",tc);b.AddContent(q++,$"[{path[i]}]");b.CloseElement();}
  b.CloseElement();}

private static void AppendLB(RenderTreeBuilder b,ref int q,double lf,int count,int cap)
{ string fc=lf>.85?"crit":lf>.65?"warn":"";double pct=Math.Min(lf*100,100);
  b.OpenElement(q++,"div");b.AddAttribute(q++,"class","cmp-load-bar-wrap");
  b.OpenElement(q++,"div");b.AddAttribute(q++,"class","cmp-load-bar-bg");
  b.OpenElement(q++,"div");b.AddAttribute(q++,"class",$"cmp-load-bar-fill {fc}");b.AddAttribute(q++,"style",$"width:{pct:F0}%");b.CloseElement();
  b.CloseElement();b.OpenElement(q++,"span");b.AddAttribute(q++,"class","cmp-load-val");b.AddContent(q++,$"α={lf:F2} ({count}/{cap})");b.CloseElement();b.CloseElement();}

// ══ DH / RH / Cuckoo / RBT simulations ══════════════════════════════════════
private static DhSlot[] NewDhTable(int c)=>Enumerable.Range(0,c).Select(_=>new DhSlot()).ToArray();
private static int DhH1(string k,int c){uint h=5381;foreach(char ch in k)h=((h<<5)+h)^(uint)ch;return(int)(h%(uint)c);}
private static int DhH2(string k,int c){uint h=0;foreach(char ch in k)h=(uint)ch+(h<<6)+(h<<16)-h;int s=1+(int)(h%(uint)(c-1));if(s%2==0)s++;if(s>=c)s=c-2;if(s<1)s=1;return s;}
private bool DhContains(SS st,string k){var t=st.DhTable!;int c=t.Length,h1=DhH1(k,c),h2=DhH2(k,c);for(int i=0;i<c;i++){int si=(h1+i*h2)%c;if(t[si].State==DhS.Empty)return false;if(t[si].State==DhS.Occupied&&t[si].Key==k)return true;}return false;}
private bool DhAdd(SS st,string k,string v){DhResize(st);var t=st.DhTable!;int c=t.Length,h1=DhH1(k,c),h2=DhH2(k,c),tomb=-1;for(int i=0;i<c;i++){int si=(h1+i*h2)%c;if(t[si].State==DhS.Empty){int at=tomb>=0?tomb:si;t[at]=new DhSlot{State=DhS.Occupied,Key=k,Value=v,HomeSlot=h1};return true;}if(t[si].State==DhS.Deleted&&tomb<0)tomb=si;if(t[si].State==DhS.Occupied&&t[si].Key==k)return false;}if(tomb>=0){t[tomb]=new DhSlot{State=DhS.Occupied,Key=k,Value=v,HomeSlot=h1};return true;}return false;}
private void DhInsertOrAssign(SS st,string k,string v){var t=st.DhTable!;int c=t.Length,h1=DhH1(k,c),h2=DhH2(k,c);for(int i=0;i<c;i++){int si=(h1+i*h2)%c;if(t[si].State==DhS.Occupied&&t[si].Key==k){t[si].Value=v;return;}}DhAdd(st,k,v);}
private bool DhRemove(SS st,string k){var t=st.DhTable!;int c=t.Length,h1=DhH1(k,c),h2=DhH2(k,c);for(int i=0;i<c;i++){int si=(h1+i*h2)%c;if(t[si].State==DhS.Empty)return false;if(t[si].State==DhS.Occupied&&t[si].Key==k){t[si]=new DhSlot{State=DhS.Deleted};return true;}}return false;}
private void DhResize(SS st){double lf=st.DhTable!.Count(s=>s.State==DhS.Occupied)/(double)st.DhTable.Length;if(lf<.65)return;int nc=NextPrime(st.DhTable.Length*2+1);var old=st.DhTable;st.DhTable=NewDhTable(nc);foreach(var s in old.Where(s=>s.State==DhS.Occupied))DhAdd(st,s.Key,s.Value);}

private static RhSlot[] NewRhTable(int c)=>Enumerable.Range(0,c).Select(_=>new RhSlot()).ToArray();
private static int RhHash(string k,int c){uint h=5381;foreach(char ch in k)h=((h<<5)+h)^(uint)ch;return(int)(h%(uint)c);}
private bool RhContains(SS st,string k){var t=st.RhTable!;int c=t.Length,home=RhHash(k,c);for(int i=0;i<c;i++){int si=(home+i)%c;if(t[si].State==RhS.Empty)return false;if(t[si].Psl<i)return false;if(t[si].State==RhS.Occupied&&t[si].Key==k)return true;}return false;}
private bool RhAdd(SS st,string k,string v){RhResize(st);var t=st.RhTable!;int c=t.Length,home=RhHash(k,c);var ins=new RhSlot{State=RhS.Occupied,Key=k,Value=v,HomeSlot=home,Psl=0};for(int i=0;i<c;i++){int si=(home+i)%c;if(t[si].State==RhS.Empty){t[si]=ins;return true;}if(t[si].State==RhS.Occupied&&t[si].Key==ins.Key)return false;if(ins.Psl>t[si].Psl){var d=t[si];t[si]=ins;ins=d;home=RhHash(ins.Key,c);}ins.Psl++;}return false;}
private void RhInsertOrAssign(SS st,string k,string v){var t=st.RhTable!;int c=t.Length,home=RhHash(k,c);for(int i=0;i<c;i++){int si=(home+i)%c;if(t[si].State==RhS.Occupied&&t[si].Key==k){t[si].Value=v;return;}}RhAdd(st,k,v);}
private bool RhRemove(SS st,string k){var t=st.RhTable!;int c=t.Length,home=RhHash(k,c);for(int i=0;i<c;i++){int si=(home+i)%c;if(t[si].State==RhS.Empty)return false;if(t[si].Psl<i)return false;if(t[si].State==RhS.Occupied&&t[si].Key==k){int cur=si;while(true){int nx=(cur+1)%c;if(t[nx].State==RhS.Empty||t[nx].Psl==0){t[cur]=new RhSlot();break;}t[cur]=new RhSlot{State=RhS.Occupied,Key=t[nx].Key,Value=t[nx].Value,HomeSlot=t[nx].HomeSlot,Psl=t[nx].Psl-1};cur=nx;}return true;}}return false;}
private void RhResize(SS st){double lf=st.RhTable!.Count(s=>s.State==RhS.Occupied)/(double)st.RhTable.Length;if(lf<.7)return;int nc=NextPrime(st.RhTable.Length*2+1);var old=st.RhTable;st.RhTable=NewRhTable(nc);foreach(var s in old.Where(s=>s.State==RhS.Occupied))RhAdd(st,s.Key,s.Value);}

private static int CkH1(string k,int c){uint h=2166136261u;foreach(char ch in k){h^=(uint)ch;h*=16777619u;}return(int)(h%(uint)c);}
private static int CkH2(string k,int c){uint h=2166136261u^0x5bd1e995u;foreach(char ch in k){h^=(uint)ch;h*=16777619u;h+=0x27d4eb2du;}return(int)(h%(uint)c);}
private static int CkNextPow2(int n,int min=1){int p=min;while(p<n)p<<=1;return p;}
private static void CkRebuildTables(SS st,CuckooSnapshot snap)
{ int cap=CkNextPow2(Math.Max(snap.Count,1)*2,8);
  st.CkT1=Enumerable.Range(0,cap).Select(i=>new CkVizSlot{Idx=i}).ToList();
  st.CkT2=Enumerable.Range(0,cap).Select(i=>new CkVizSlot{Idx=i}).ToList();
  foreach(var e in snap.Entries){if(e.State!=CuckooSlotState.Occupied)continue;int s1=CkH1(e.Key,cap),s2=CkH2(e.Key,cap);
    if(!st.CkT1[s1].Occupied){st.CkT1[s1].Key=e.Key;st.CkT1[s1].Value=e.Value;}
    else if(!st.CkT2[s2].Occupied){st.CkT2[s2].Key=e.Key;st.CkT2[s2].Value=e.Value;}
    else{bool p=false;for(int i=0;i<cap&&!p;i++)if(!st.CkT1[i].Occupied){st.CkT1[i].Key=e.Key;st.CkT1[i].Value=e.Value;p=true;}
    if(!p)for(int i=0;i<cap&&!p;i++)if(!st.CkT2[i].Occupied){st.CkT2[i].Key=e.Key;st.CkT2[i].Value=e.Value;p=true;}}}}

private bool RbtIsNil(string slug,RbtNode? n)=>n==null||n==GetNil(slug);
private RbtNode? RbtSearch(string slug,RbtNode? n,string k){if(RbtIsNil(slug,n))return null;int c=string.Compare(k,n!.Key,StringComparison.Ordinal);return c==0?n:RbtSearch(slug,c<0?n.Left:n.Right,k);}
private bool RbtInsertKey(string slug,string k,string v){var nil=GetNil(slug);if(!_rbtRoots.ContainsKey(slug))_rbtRoots[slug]=null;if(RbtSearch(slug,_rbtRoots[slug],k)!=null)return false;var z=new RbtNode{Key=k,Value=v,Color=RbColor.Red,Left=nil,Right=nil,Parent=nil};RbtNode? y=nil;var x=_rbtRoots[slug]??nil;while(!RbtIsNil(slug,x)){y=x;x=string.Compare(k,x!.Key,StringComparison.Ordinal)<0?x.Left!:x.Right!;}z.Parent=y;if(RbtIsNil(slug,y))_rbtRoots[slug]=z;else if(string.Compare(k,y!.Key,StringComparison.Ordinal)<0)y.Left=z;else y.Right=z;RbtIF(slug,z);return true;}
private void RbtInsertOrAssign(string slug,string k,string v){var n=RbtSearch(slug,_rbtRoots.GetValueOrDefault(slug),k);if(n!=null){n.Value=v;return;}RbtInsertKey(slug,k,v);}
private bool RbtDelete(string slug,string k){var z=RbtSearch(slug,_rbtRoots.GetValueOrDefault(slug),k);if(z==null||RbtIsNil(slug,z))return false;var nil=GetNil(slug);var y=z;var yo=y.Color;RbtNode x;if(RbtIsNil(slug,z.Left!)){x=z.Right!;RbtTP(slug,z,z.Right!);}else if(RbtIsNil(slug,z.Right!)){x=z.Left!;RbtTP(slug,z,z.Left!);}else{y=RbtMn(slug,z.Right!);yo=y.Color;x=y.Right!;if(y.Parent==z)x.Parent=y;else{RbtTP(slug,y,y.Right!);y.Right=z.Right;y.Right!.Parent=y;}RbtTP(slug,z,y);y.Left=z.Left;y.Left!.Parent=y;y.Color=z.Color;}if(yo==RbColor.Black)RbtDF(slug,x);return true;}
private void RbtTP(string s,RbtNode u,RbtNode v){var nil=GetNil(s);if(u.Parent==nil||u.Parent==null)_rbtRoots[s]=v;else if(u==u.Parent!.Left)u.Parent.Left=v;else u.Parent.Right=v;v.Parent=u.Parent!;}
private RbtNode RbtMn(string s,RbtNode n){while(!RbtIsNil(s,n.Left!))n=n.Left!;return n;}
private int RbtCount(string s){int c=0;void W(RbtNode? n){if(RbtIsNil(s,n))return;c++;W(n!.Left);W(n.Right);}W(_rbtRoots.GetValueOrDefault(s));return c;}
private int RbtHeight(string s){int H(RbtNode? n)=>RbtIsNil(s,n)?0:1+Math.Max(H(n!.Left),H(n.Right));return H(_rbtRoots.GetValueOrDefault(s));}
private void RbtLR(string s,RbtNode x){var nil=GetNil(s);var y=x.Right!;x.Right=y.Left;if(!RbtIsNil(s,y.Left))y.Left!.Parent=x;y.Parent=x.Parent;if(x.Parent==nil||x.Parent==null)_rbtRoots[s]=y;else if(x==x.Parent!.Left)x.Parent.Left=y;else x.Parent.Right=y;y.Left=x;x.Parent=y;}
private void RbtRR(string s,RbtNode y){var nil=GetNil(s);var x=y.Left!;y.Left=x.Right;if(!RbtIsNil(s,x.Right))x.Right!.Parent=y;x.Parent=y.Parent;if(y.Parent==nil||y.Parent==null)_rbtRoots[s]=x;else if(y==y.Parent!.Left)y.Parent.Left=x;else y.Parent.Right=x;x.Right=y;y.Parent=x;}
private void RbtIF(string s,RbtNode z){while(z.Parent?.Color==RbColor.Red){if(z.Parent==z.Parent?.Parent?.Left){var y=z.Parent.Parent!.Right!;if(y.Color==RbColor.Red){z.Parent.Color=RbColor.Black;y.Color=RbColor.Black;z.Parent.Parent!.Color=RbColor.Red;z=z.Parent.Parent!;}else{if(z==z.Parent.Right){z=z.Parent;RbtLR(s,z);}z.Parent!.Color=RbColor.Black;z.Parent.Parent!.Color=RbColor.Red;RbtRR(s,z.Parent.Parent!);}}else{var y=z.Parent!.Parent!.Left!;if(y.Color==RbColor.Red){z.Parent.Color=RbColor.Black;y.Color=RbColor.Black;z.Parent.Parent!.Color=RbColor.Red;z=z.Parent.Parent!;}else{if(z==z.Parent.Left){z=z.Parent;RbtRR(s,z);}z.Parent!.Color=RbColor.Black;z.Parent.Parent!.Color=RbColor.Red;RbtLR(s,z.Parent.Parent!);}}if(z==_rbtRoots.GetValueOrDefault(s))break;}if(_rbtRoots.TryGetValue(s,out var r)&&r!=null)r.Color=RbColor.Black;}
private void RbtDF(string s,RbtNode x){while(x!=_rbtRoots.GetValueOrDefault(s)&&x.Color==RbColor.Black){if(x==x.Parent!.Left){var w=x.Parent.Right!;if(w.Color==RbColor.Red){w.Color=RbColor.Black;x.Parent.Color=RbColor.Red;RbtLR(s,x.Parent);w=x.Parent.Right!;}if(w.Left!.Color==RbColor.Black&&w.Right!.Color==RbColor.Black){w.Color=RbColor.Red;x=x.Parent;}else{if(w.Right!.Color==RbColor.Black){w.Left!.Color=RbColor.Black;w.Color=RbColor.Red;RbtRR(s,w);w=x.Parent!.Right!;}w.Color=x.Parent!.Color;x.Parent.Color=RbColor.Black;w.Right!.Color=RbColor.Black;RbtLR(s,x.Parent);x=_rbtRoots[s]!;}}else{var w=x.Parent!.Left!;if(w.Color==RbColor.Red){w.Color=RbColor.Black;x.Parent.Color=RbColor.Red;RbtRR(s,x.Parent);w=x.Parent.Left!;}if(w.Right!.Color==RbColor.Black&&w.Left!.Color==RbColor.Black){w.Color=RbColor.Red;x=x.Parent;}else{if(w.Left!.Color==RbColor.Black){w.Right!.Color=RbColor.Black;w.Color=RbColor.Red;RbtLR(s,w);w=x.Parent!.Left!;}w.Color=x.Parent!.Color;x.Parent.Color=RbColor.Black;w.Left!.Color=RbColor.Black;RbtRR(s,x.Parent);x=_rbtRoots[s]!;}}}x.Color=RbColor.Black;}

