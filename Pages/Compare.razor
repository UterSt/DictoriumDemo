@page "/compare"
@using Microsoft.AspNetCore.Components.Rendering
@inject DictoriumJsService Dtr
@inject DataStructureService DS

<PageTitle>Сравнение структур — Dictorium Demo</PageTitle>

<div class="compare-page-wrap">
    <h1 class="compare-h1">Сравнение структур данных</h1>
    <p class="compare-sub">Выберите до 3 структур — операции выполняются синхронно с анимацией в каждой.</p>

    <div class="selector-area">
        @for (int i = 0; i < 3; i++)
        {
            int idx = i;
            var selected = _selected[idx];
            <div class="selector-slot">
                <div class="slot-lbl">Структура @(idx + 1)</div>
                @if (selected == null) { <div class="slot-empty">— выберите из списка ниже —</div> }
                else
                {
                    var cat = DS.GetCategoryForStructure(selected.Slug);
                    <div class="slot-filled">
                        <span class="slot-cat-icon">@cat?.Icon</span>
                        <div class="slot-info"><strong>@selected.NameRu</strong><small>@cat?.NameRu</small></div>
                        <button class="slot-rm" @onclick="() => RemoveSlot(idx)">&#10005;</button>
                    </div>
                }
                <div class="slot-drop">
                    @foreach (var cat in DS.GetAllCategories())
                    {
                        var structs = cat.Structures.Where(s => s.Slug != "b-tree" && s.Slug != "b-plus-tree").ToList();
                        if (!structs.Any()) continue;
                        <div class="dd-grp">
                            <div class="dd-grp-lbl" style="color:@cat.AccentColor">@cat.Icon &nbsp;@cat.NameRu</div>
                            @foreach (var s in structs)
                            {
                                bool taken = _selected.Any(x => x?.Slug == s.Slug);
                                <button class="dd-item @(selected?.Slug == s.Slug ? "selected" : "") @(taken && selected?.Slug != s.Slug ? "disabled" : "")"
                                        disabled="@(taken && selected?.Slug != s.Slug)"
                                        @onclick="() => Select(idx, s)">
                                    <span class="dd-num" style="color:@cat.AccentColor">#@s.IssueNumber</span>
                                    <span>@s.NameRu</span><span class="dd-en">@s.Name</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @{ var active = _selected.Where(s => s != null).Select(s => s!).ToList(); }

    @if (active.Count >= 2)
    {
        <div class="cmp-wasm-bar">
            @if (!_wasmReady) { <span class="cmp-wasm-loading">○ Загрузка WebAssembly...</span> }
            else { <span class="cmp-wasm-ok">● WASM готов</span><span class="cmp-wasm-sep">·</span><span class="cmp-wasm-note">Реальная библиотека Dictorium · анимация шаг за шагом</span> }
        </div>

        @if (_wasmReady)
        {
            <div class="cmp-ctrl-bar">
                <div class="cmp-ctrl-inputs">
                    <div class="cmp-ctrl-field">
                        <label class="cmp-ctrl-lbl">Ключ</label>
                        <input class="search-input cmp-input" @bind="_keyInput" @bind:event="oninput" placeholder="apple" disabled="@_busy" />
                    </div>
                    <div class="cmp-ctrl-field">
                        <label class="cmp-ctrl-lbl">Значение</label>
                        <input class="search-input cmp-input" @bind="_valInput" @bind:event="oninput" placeholder="яблоко" disabled="@_busy" />
                    </div>
                </div>
                <div class="cmp-ctrl-ops">
                    <button class="btn-op btn-search"  @onclick="DoContains"       disabled="@(_busy||string.IsNullOrWhiteSpace(_keyInput))">▶ ContainsKey</button>
                    <button class="btn-op btn-add"     @onclick="DoAdd"            disabled="@(_busy||string.IsNullOrWhiteSpace(_keyInput)||string.IsNullOrWhiteSpace(_valInput))">+ Add</button>
                    <button class="btn-op btn-add"     @onclick="DoInsertOrAssign" disabled="@(_busy||string.IsNullOrWhiteSpace(_keyInput)||string.IsNullOrWhiteSpace(_valInput))">± InsertOrAssign</button>
                    <button class="btn-op btn-remove"  @onclick="DoRemove"         disabled="@(_busy||string.IsNullOrWhiteSpace(_keyInput))">− Remove</button>
                    <button class="btn-op btn-clear"   @onclick="DoClear"          disabled="@_busy">⊘ Clear</button>
                    <button class="btn-op"             @onclick="LoadSample"       disabled="@_busy">Загрузить пример</button>
                </div>
                @if (!string.IsNullOrEmpty(_globalStatus))
                {
                    <div class="cmp-gstatus @_globalStatusCls"><strong>@_globalStatusIcon</strong> @_globalStatus</div>
                }
            </div>

            <div class="cmp-viz-grid cmp-viz-cols-@active.Count">
                @foreach (var s in active)
                {
                    var cat = DS.GetCategoryForStructure(s.Slug);
                    var st  = GetState(s.Slug);
                    <div class="cmp-viz-panel">
                        <div class="cmp-viz-panel-head" style="border-top:3px solid @(cat?.AccentColor ?? "#4ade80")">
                            <span class="cmp-viz-panel-icon">@cat?.Icon</span>
                            <div>
                                <div class="cmp-viz-panel-name">@s.NameRu</div>
                                <div class="cmp-viz-panel-eng">@s.Name</div>
                            </div>
                            <div class="cmp-viz-panel-meta">
                                <span class="cmp-meta-item">n=@st.Count</span>
                                @if (st.Capacity > 0) { <span class="cmp-meta-item">cap=@st.Capacity</span><span class="cmp-meta-item">@("\u03b1")=@st.LoadFactor.ToString("F2")</span> }
                                @if (st.Height > 0)   { <span class="cmp-meta-item">h=@st.Height</span> }
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(st.LastResult))
                        { <div class="cmp-viz-result @st.ResultCls">@st.LastResult</div> }
                        @if (!string.IsNullOrEmpty(st.StepHint))
                        { <div class="cmp-step-hint">@st.StepHint</div> }
                        <div class="cmp-viz-body">@RenderViz(s.Slug, st)</div>
                        <div class="cmp-viz-log">
                            @foreach (var line in st.Log.TakeLast(6)) { <div class="log-line @line.Cls">@line.Text</div> }
                        </div>
                    </div>
                }
            </div>

            <div class="table-wrap" style="margin-top:12px;">
                <table class="comp-table">
                    <thead>
                        <tr>
                            <th class="lbl-th">Параметр</th>
                            @foreach (var s in active) { var cat = DS.GetCategoryForStructure(s.Slug); <th><div class="ct-head-inner"><span>@cat?.Icon</span><strong>@s.NameRu</strong><small>@s.Name</small></div></th> }
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="section-tr"><td colspan="@(active.Count+1)">Временная сложность</td></tr>
                        <tr><td class="lbl-td">Поиск</td>   @foreach(var s in active){<td><span class="@CxCls(s.TimeComplexitySearch)">@s.TimeComplexitySearch</span></td>}</tr>
                        <tr><td class="lbl-td">Вставка</td> @foreach(var s in active){<td><span class="@CxCls(s.TimeComplexityInsert)">@s.TimeComplexityInsert</span></td>}</tr>
                        <tr><td class="lbl-td">Удаление</td>@foreach(var s in active){<td><span class="@CxCls(s.TimeComplexityDelete)">@s.TimeComplexityDelete</span></td>}</tr>
                        <tr><td class="lbl-td">Память</td>  @foreach(var s in active){<td><span class="ct-mono">@s.SpaceComplexity</span></td>}</tr>
                        <tr class="section-tr"><td colspan="@(active.Count+1)">Плюсы / Минусы</td></tr>
                        <tr><td class="lbl-td">+ Плюсы</td> @foreach(var s in active){<td>@foreach(var p in s.Pros){<span class="ct-item pro">@p</span>}</td>}</tr>
                        <tr><td class="lbl-td">− Минусы</td>@foreach(var s in active){<td>@foreach(var c in s.Cons){<span class="ct-item con">@c</span>}</td>}</tr>
                    </tbody>
                </table>
            </div>
        }
    }
    else if (active.Count == 1) { <p class="comp-hint">Выберите ещё минимум одну структуру.</p> }
    else                        { <p class="comp-hint">Выберите 2–3 структуры для сравнения.</p> }
</div>

<style>
