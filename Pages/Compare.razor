@code {
// ══ Types ════════════════════════════════════════════════════════════════════
private record LogLine(string Text, string Cls);
private enum AState { Normal, Scanning, Hit, Miss }

private class SS
{
    public int    WasmHandle = -1;
    public bool   Initialized;
    public int    Count, Capacity, Height, MaxLevel;
    public double LoadFactor;
    public string LastResult = "", ResultCls = "", StepHint = "";
    public readonly List<LogLine> Log = new();

    // Snapshots
    public LpSnapshot?        LpSnap;
    public QpSnapshot?        QpSnap;
    public DhSlot[]?          DhTable;
    public RhSlot[]?          RhTable;
    public List<ChainBucket>? ChainBuckets;
    public List<CkVizSlot>    CkT1 = new(), CkT2 = new();
    public List<DictItem>?    PhItems;
    public int  PhHandle = -1;
    public bool PhBuilt;
    public List<DictItem>? SlItems;
    public Dictionary<string,int> SlNodeLevels = new();

    // Animation — hash tables
    public int              ProbeCursor = -1, ProbeHome = -1;
    public List<int>        ProbePath   = new();
    public bool             ProbeHit;
    public Dictionary<int,string> SlotAnimCls = new();
    public (string T, int I)? CkProbe, CkResult;
    public int?    ChainProbeBucket;
    public string? ChainProbeKey;
    public string? PhHitKey;

    // Animation — trees / skip list
    public HashSet<string>          AnimPath  = new();
    public HashSet<(string,string)> AnimEdges = new();
    public string? AnimHit, AnimMiss;

    // SVG output
    public string TreeSvg = "", SlSvg = "";
}

private class CkVizSlot { public int Idx; public string Key="",Value=""; public bool Occupied => !string.IsNullOrEmpty(Key); }

private enum DhS { Empty, Occupied, Deleted }
private class DhSlot { public DhS State=DhS.Empty; public string Key="",Value=""; public int HomeSlot=-1; }
private enum RhS { Empty, Occupied }
private class RhSlot { public RhS State=RhS.Empty; public string Key="",Value=""; public int HomeSlot=-1; public int Psl; }

private enum RbColor { Red, Black }
private class RbtNode { public string Key="",Value=""; public RbColor Color=RbColor.Black; public RbtNode? Left,Right,Parent; }

// ══ Fields ═══════════════════════════════════════════════════════════════════
[SupplyParameterFromQuery(Name="a")] public string? PreloadA { get; set; }

private DataStructureInfo?[] _selected = new DataStructureInfo?[3];
private bool   _wasmReady;
private string _keyInput="", _valInput="";
private bool   _busy;
private string _globalStatus="", _globalStatusCls="", _globalStatusIcon="";

private readonly Dictionary<string,SS>       _states   = new();
private readonly Dictionary<string,RbtNode?> _rbtRoots = new();
private readonly Dictionary<string,RbtNode>  _rbtNils  = new();
// Tiny BST for tree traversal animation (avl / treap)
private readonly Dictionary<string,TinyNode?> _tinyTrees = new();
// AVL value cache
private readonly Dictionary<string,Dictionary<string,string>> _avlValues = new();

private const int StepMs = 300;

// ══ Lifecycle ════════════════════════════════════════════════════════════════
protected override void OnInitialized()
{ if (!string.IsNullOrEmpty(PreloadA)) _selected[0] = DS.GetStructure(PreloadA); }

protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (!firstRender) return;
    await Dtr.InitAsync(); _wasmReady = true;
    foreach (var s in _selected.Where(s=>s!=null).Select(s=>s!))
        await EnsureInitAsync(s.Slug);
    StateHasChanged();
}

// ══ Selection ════════════════════════════════════════════════════════════════
private async Task Select(int slot, DataStructureInfo s)
{
    if (_selected[slot]?.Slug == s.Slug) { _selected[slot]=null; StateHasChanged(); return; }
    _selected[slot] = s;
    if (_wasmReady) await EnsureInitAsync(s.Slug);
    StateHasChanged();
}
private void RemoveSlot(int idx) { _selected[idx]=null; StateHasChanged(); }

// ══ Init ═════════════════════════════════════════════════════════════════════
private SS GetState(string slug)
{ if (!_states.TryGetValue(slug,out var st)) { st=new SS(); _states[slug]=st; } return st; }

private RbtNode GetNil(string slug)
{ if (!_rbtNils.TryGetValue(slug,out var n)) { n=new RbtNode{Color=RbColor.Black}; _rbtNils[slug]=n; } return n; }

private async Task EnsureInitAsync(string slug)
{
    var st = GetState(slug); if (st.Initialized) return;
    switch (slug)
    {
        case "open-hashing":       st.WasmHandle = await Dtr.ChainingCreateAsync(); break;
        case "linear-probing":     st.WasmHandle = await Dtr.LpCreateAsync();       break;
        case "quadratic-probing":  st.WasmHandle = await Dtr.QpCreateAsync();       break;
        case "double-hashing":     st.DhTable    = NewDhTable(11);                  break;
        case "robin-hood-hashing": st.RhTable    = NewRhTable(11);                  break;
        case "cuckoo-hashing":     st.WasmHandle = await Dtr.CuckooCreateAsync();   break;
        case "perfect-hashing":    st.PhItems    = new(); st.PhBuilt=false;         break;
        case "avl-tree":           st.WasmHandle = await Dtr.AvlCreateAsync();      break;
        case "red-black-tree":     _rbtRoots[slug]=null; _rbtNils[slug]=new RbtNode{Color=RbColor.Black}; break;
        case "skip-list":          st.WasmHandle = await Dtr.SlCreateAsync();       break;
        case "cartesian-tree":     st.WasmHandle = await Dtr.TreapCreateAsync();    break;
    }
    st.Initialized = true;
    await RefreshAsync(slug);
}

// ══ Sync operations ═══════════════════════════════════════════════════════════
private async Task DoContains()
{ if(_busy||string.IsNullOrWhiteSpace(_keyInput))return; _busy=true; var key=_keyInput.Trim(); SetGS($"ContainsKey(\"{key}\")...","","▶");
  await Task.WhenAll(ActiveSlugs().Select(slug=>AnimContainsAsync(slug,key)));
  SetGS($"ContainsKey(\"{key}\") выполнено","status-ok","✓"); _busy=false; StateHasChanged(); }

private async Task DoAdd()
{ if(_busy||string.IsNullOrWhiteSpace(_keyInput)||string.IsNullOrWhiteSpace(_valInput))return; _busy=true;
  var key=_keyInput.Trim(); var val=_valInput.Trim(); SetGS($"Add(\"{key}\")...","","＋");
  await Task.WhenAll(ActiveSlugs().Select(slug=>AnimAddAsync(slug,key,val)));
  SetGS($"Add(\"{key}\") выполнено","status-ok","✓"); _busy=false; StateHasChanged(); }

private async Task DoInsertOrAssign()
{ if(_busy||string.IsNullOrWhiteSpace(_keyInput)||string.IsNullOrWhiteSpace(_valInput))return; _busy=true;
  var key=_keyInput.Trim(); var val=_valInput.Trim(); SetGS($"InsertOrAssign(\"{key}\")...","","±");
  await Task.WhenAll(ActiveSlugs().Select(slug=>AnimIoAAsync(slug,key,val)));
  SetGS($"InsertOrAssign(\"{key}\") выполнено","status-ok","✓"); _busy=false; StateHasChanged(); }

private async Task DoRemove()
{ if(_busy||string.IsNullOrWhiteSpace(_keyInput))return; _busy=true; var key=_keyInput.Trim(); SetGS($"Remove(\"{key}\")...","","−");
  await Task.WhenAll(ActiveSlugs().Select(slug=>AnimRemoveAsync(slug,key)));
  SetGS($"Remove(\"{key}\") выполнено","status-ok","✓"); _busy=false; StateHasChanged(); }

private async Task DoClear()
{ if(_busy)return; _busy=true; SetGS("Clear()...","","⊘");
  foreach(var slug in ActiveSlugs()) { var st=GetState(slug); await EnsureInitAsync(slug); await SlugClearAsync(slug,st); st.StepHint=""; ClearAnim(st); AddLog(st,"⊘ Clear()","log-op"); await RefreshAsync(slug); }
  SetGS("Clear() выполнено","status-ok","✓"); _busy=false; StateHasChanged(); }

private async Task LoadSample()
{ if(_busy)return; _busy=true; SetGS("Загрузка примера...","","→");
  var slugs=ActiveSlugs();
  foreach(var slug in slugs){var st=GetState(slug);await EnsureInitAsync(slug);await SlugClearAsync(slug,st);ClearAnim(st);}
  foreach(var(k,v) in SamplePairs) foreach(var slug in slugs) await SlugAddAsync(slug,GetState(slug),k,v);
  foreach(var slug in slugs){await RefreshAsync(slug);AddLog(GetState(slug),$"→ Загружено {SamplePairs.Length} эл.","log-op");}
  SetGS($"Загружено {SamplePairs.Length} элементов","status-ok","✓"); _busy=false; StateHasChanged(); }

private static readonly (string Key,string Value)[] SamplePairs =
{ ("apple","яблоко"),("banana","банан"),("cherry","вишня"),("date","финик"),
  ("elderberry","бузина"),("fig","инжир"),("grape","виноград"),("honeydew","дыня") };

private List<string> ActiveSlugs() => _selected.Where(s=>s!=null).Select(s=>s!.Slug).ToList();

// ══ Animated per-slug operations ══════════════════════════════════════════════
private async Task AnimContainsAsync(string slug, string key)
{
    var st=GetState(slug); await EnsureInitAsync(slug); ClearAnim(st); await RefreshAsync(slug);
    bool found;
    if (IsHashTable(slug)) { found=await SlugContainsAsync(slug,st,key); await AnimHashProbeAsync(slug,st,key,found?AState.Hit:AState.Miss); }
    else if (IsTree(slug)) { found=await SlugContainsAsync(slug,st,key); await AnimTreeSearchAsync(slug,st,key,found?AState.Hit:AState.Miss); }
    else if (slug=="skip-list") { found=await Dtr.SlContainsAsync(st.WasmHandle,key); await AnimSlSearchAsync(st,key,found?AState.Hit:AState.Miss); }
    else found=await SlugContainsAsync(slug,st,key);
    st.LastResult=found?$"ContainsKey(\"{key}\") → true":$"ContainsKey(\"{key}\") → false";
    st.ResultCls=found?"status-ok":"status-err"; st.StepHint="";
    AddLog(st,st.LastResult,found?"log-ok":"log-miss");
    ClearAnim(st); await RefreshAsync(slug); StateHasChanged();
}

private async Task AnimAddAsync(string slug, string key, string val)
{
    var st=GetState(slug); await EnsureInitAsync(slug); ClearAnim(st); await RefreshAsync(slug);
    bool ok;
    if (IsHashTable(slug))
    { await AnimHashProbeAsync(slug,st,key,AState.Normal);
      ok=await SlugAddAsync(slug,st,key,val); await RefreshAsync(slug);
      await AnimHashProbeAsync(slug,st,key,ok?AState.Hit:AState.Miss); await Task.Delay(400); }
    else if (IsTree(slug))
    { await AnimTreeSearchAsync(slug,st,key,AState.Normal);
      ok=await SlugAddAsync(slug,st,key,val); await RefreshAsync(slug);
      ClearAnim(st); st.AnimHit=key; BuildTreeSvg(slug,st); StateHasChanged(); await Task.Delay(600); }
    else if (slug=="skip-list")
    { ok=await Dtr.SlAddAsync(st.WasmHandle,key,val);
      if(ok&&!st.SlNodeLevels.ContainsKey(key)) st.SlNodeLevels[key]=SlGenLevel(st.MaxLevel);
      await RefreshAsync(slug); st.AnimHit=key; BuildSlSvg(st); StateHasChanged(); await Task.Delay(600); }
    else { ok=await SlugAddAsync(slug,st,key,val); await RefreshAsync(slug); }
    st.LastResult=ok?$"Add(\"{key}\") → ok":$"Add(\"{key}\") → dup";
    st.ResultCls=ok?"status-ok":"status-warn"; st.StepHint="";
    AddLog(st,ok?$"+ Add(\"{key}\",\"{val}\")":$"✗ dup: \"{key}\"",ok?"log-ok":"log-err");
    ClearAnim(st); await RefreshAsync(slug); StateHasChanged();
}

private async Task AnimIoAAsync(string slug, string key, string val)
{
    var st=GetState(slug); await EnsureInitAsync(slug); ClearAnim(st); await RefreshAsync(slug);
    if (IsHashTable(slug))
    { await AnimHashProbeAsync(slug,st,key,AState.Normal);
      await SlugInsertOrAssignAsync(slug,st,key,val); await RefreshAsync(slug);
      await AnimHashProbeAsync(slug,st,key,AState.Hit); await Task.Delay(400); }
    else if (IsTree(slug))
    { await AnimTreeSearchAsync(slug,st,key,AState.Normal);
      await SlugInsertOrAssignAsync(slug,st,key,val); await RefreshAsync(slug);
      ClearAnim(st); st.AnimHit=key; BuildTreeSvg(slug,st); StateHasChanged(); await Task.Delay(600); }
    else if (slug=="skip-list")
    { await Dtr.SlInsertOrAssignAsync(st.WasmHandle,key,val);
      if(!st.SlNodeLevels.ContainsKey(key)) st.SlNodeLevels[key]=SlGenLevel(st.MaxLevel);
      await RefreshAsync(slug); st.AnimHit=key; BuildSlSvg(st); StateHasChanged(); await Task.Delay(600); }
    else { await SlugInsertOrAssignAsync(slug,st,key,val); await RefreshAsync(slug); }
    st.LastResult=$"InsertOrAssign(\"{key}\") → ok"; st.ResultCls="status-ok"; st.StepHint="";
    AddLog(st,$"± InsertOrAssign(\"{key}\",\"{val}\")","log-ok");
    ClearAnim(st); await RefreshAsync(slug); StateHasChanged();
}

private async Task AnimRemoveAsync(string slug, string key)
{
    var st=GetState(slug); await EnsureInitAsync(slug); ClearAnim(st); await RefreshAsync(slug);
    bool ok;
    if (IsHashTable(slug))
    { await AnimHashProbeAsync(slug,st,key,AState.Normal);
      ok=await SlugRemoveAsync(slug,st,key); await RefreshAsync(slug);
      if(ok) await AnimHashProbeAsync(slug,st,key,AState.Miss);
      await Task.Delay(350); }
    else if (IsTree(slug))
    { await AnimTreeSearchAsync(slug,st,key,AState.Miss); await Task.Delay(250);
      ok=await SlugRemoveAsync(slug,st,key); await RefreshAsync(slug); }
    else if (slug=="skip-list")
    { ok=await Dtr.SlRemoveAsync(st.WasmHandle,key); st.SlNodeLevels.Remove(key); await RefreshAsync(slug); }
    else { ok=await SlugRemoveAsync(slug,st,key); await RefreshAsync(slug); }
    st.LastResult=ok?$"Remove(\"{key}\") → ok":$"Remove(\"{key}\") → not found";
    st.ResultCls=ok?"status-ok":"status-err"; st.StepHint="";
    AddLog(st,ok?$"− Remove(\"{key}\")":$"✗ not found: \"{key}\"",ok?"log-ok":"log-miss");
    ClearAnim(st); await RefreshAsync(slug); StateHasChanged();
}

// ══ Hash probe animations ════════════════════════════════════════════════════
private async Task AnimHashProbeAsync(string slug, SS st, string key, AState fin)
{ switch(slug)
  { case "linear-probing":     await AnimLpAsync(st,key,fin);    break;
    case "quadratic-probing":  await AnimQpAsync(st,key,fin);    break;
    case "double-hashing":     await AnimDhAsync(st,key,fin);    break;
    case "robin-hood-hashing": await AnimRhAsync(st,key,fin);    break;
    case "open-hashing":       await AnimChainAsync(st,key,fin); break;
    case "cuckoo-hashing":     await AnimCkAsync(st,key,fin);    break;
    case "perfect-hashing":    await AnimPhAsync(st,key,fin);    break; } }

private async Task AnimLpAsync(SS st, string key, AState fin)
{ var snap=st.LpSnap; if(snap==null||snap.Capacity==0)return;
  int home=LpH1(key,snap.Capacity); st.ProbeHome=home; st.SlotAnimCls.Clear();
  var path=snap.ProbePath(home,key); st.ProbePath=new List<int>(path);
  for(int i=0;i<path.Count;i++)
  { int si=path[i]; bool last=i==path.Count-1;
    string cls=last?(fin==AState.Hit?"lp-hit":fin==AState.Miss?"lp-miss":"lp-probe"):i==0?"lp-probe":"lp-collision";
    st.SlotAnimCls[si]=cls; st.ProbeCursor=si;
    st.StepHint=i==0?$"h(\"{key}\")={home} → слот [{si}]":$"Коллизия → пробируем [{si}] (шаг {i})";
    StateHasChanged(); await Task.Delay(StepMs); }
  st.ProbeHit=fin==AState.Hit; }

private async Task AnimQpAsync(SS st, string key, AState fin)
{ var snap=st.QpSnap; if(snap==null||snap.Capacity==0)return;
  int home=LpH1(key,snap.Capacity); st.ProbeHome=home; st.SlotAnimCls.Clear();
  var path=snap.QpProbePath(home,key);
  st.ProbePath=path.Select(p=>p.SlotIdx).ToList();
  for(int i=0;i<path.Count;i++)
  { var(si,step,off)=path[i]; bool last=i==path.Count-1;
    string cls=last?(fin==AState.Hit?"lp-hit":fin==AState.Miss?"lp-miss":"lp-probe"):i==0?"lp-probe":"lp-collision";
    st.SlotAnimCls[si]=cls; st.ProbeCursor=si;
    st.StepHint=i==0?$"h(\"{key}\")={home} → [{si}]":$"Шаг {step}: {home}+{step}²={home}+{off}≡{si}";
    StateHasChanged(); await Task.Delay(StepMs); }
  st.ProbeHit=fin==AState.Hit; }

private async Task AnimDhAsync(SS st, string key, AState fin)
{ var t=st.DhTable; if(t==null)return;
  int cap=t.Length,h1=DhH1(key,cap),h2=DhH2(key,cap);
  st.ProbeHome=h1; st.SlotAnimCls.Clear(); var path=new List<int>();
  for(int i=0;i<cap;i++)
  { int si=(h1+i*h2)%cap; path.Add(si);
    bool stop=t[si].State==DhS.Empty||(t[si].State==DhS.Occupied&&t[si].Key==key);
    bool last=stop; string cls=last?(fin==AState.Hit&&t[si].State==DhS.Occupied&&t[si].Key==key?"lp-hit":fin==AState.Miss?"lp-miss":"lp-probe"):i==0?"lp-probe":"lp-collision";
    st.SlotAnimCls[si]=cls; st.ProbeCursor=si;
    st.StepHint=i==0?$"h₁(\"{key}\")={h1}, h₂={h2}":$"({h1}+{i}×{h2}) mod {cap} = {si}";
    StateHasChanged(); await Task.Delay(StepMs); if(stop)break; }
  st.ProbePath=path; st.ProbeHit=fin==AState.Hit; }

private async Task AnimRhAsync(SS st, string key, AState fin)
{ var t=st.RhTable; if(t==null)return;
  int cap=t.Length,home=RhHash(key,cap); st.ProbeHome=home; st.SlotAnimCls.Clear(); var path=new List<int>();
  for(int i=0;i<cap;i++)
  { int si=(home+i)%cap; path.Add(si);
    bool found=t[si].State==RhS.Occupied&&t[si].Key==key;
    bool stop=t[si].State==RhS.Empty||(t[si].State==RhS.Occupied&&t[si].Psl<i);
    bool last=found||stop;
    string cls=last?(found&&fin==AState.Hit?"lp-hit":"lp-miss"):i==0?"lp-probe":"lp-collision";
    st.SlotAnimCls[si]=cls; st.ProbeCursor=si;
    st.StepHint=i==0?$"h(\"{key}\")={home}, PSL=0 → [{si}]":$"PSL={i} → [{si}], слот PSL={t[si].Psl}{(stop&&!found?" < "+i+" → стоп":"")}";
    StateHasChanged(); await Task.Delay(StepMs); if(last)break; }
  st.ProbePath=path; st.ProbeHit=fin==AState.Hit; }

private async Task AnimChainAsync(SS st, string key, AState fin)
{ if(st.ChainBuckets==null)return;
  int bkt=ChainHash(key,st.ChainBuckets.Count);
  st.ChainProbeBucket=bkt; st.ChainProbeKey=null;
  st.StepHint=$"h(\"{key}\")={bkt} → бакет [{bkt}]"; StateHasChanged(); await Task.Delay(StepMs);
  var chain=st.ChainBuckets.FirstOrDefault(b=>b.Slot==bkt)?.Chain??new();
  bool found=false;
  foreach(var item in chain)
  { st.ChainProbeKey=item.Key;
    st.StepHint=$"[{bkt}]: \"{item.Key}\" == \"{key}\" ?";
    StateHasChanged(); await Task.Delay(StepMs);
    if(item.Key==key){found=true;break;} }
  if(!found){st.StepHint=$"[{bkt}]: ключ не найден в цепочке (длина {chain.Count})";StateHasChanged();await Task.Delay(StepMs);} }

private async Task AnimCkAsync(SS st, string key, AState fin)
{ int cap=st.CkT1.Count==0?8:st.CkT1.Count; int s1=CkH1(key,cap),s2=CkH2(key,cap);
  st.CkProbe=("t1",s1); st.CkResult=null;
  st.StepHint=$"h₁(\"{key}\")={s1} → проверяем T1[{s1}]"; StateHasChanged(); await Task.Delay(StepMs);
  bool t1hit=st.CkT1.Count>s1&&st.CkT1[s1].Occupied&&st.CkT1[s1].Key==key;
  if(t1hit){st.CkResult=("t1",s1);st.CkProbe=null;st.StepHint=$"T1[{s1}] = \"{key}\" ✓ найдено!";StateHasChanged();await Task.Delay(StepMs);return;}
  st.StepHint=$"T1[{s1}] ≠ \"{key}\" → проверяем T2[{s2}]"; st.CkProbe=("t2",s2); StateHasChanged(); await Task.Delay(StepMs);
  bool t2hit=st.CkT2.Count>s2&&st.CkT2[s2].Occupied&&st.CkT2[s2].Key==key;
  st.CkResult=t2hit?("t2",s2):((string,int)?)null;
  st.StepHint=t2hit?$"T2[{s2}] = \"{key}\" ✓ найдено!":$"T2[{s2}] ≠ \"{key}\" → не найден";
  st.CkProbe=null; StateHasChanged(); await Task.Delay(StepMs); }

private async Task AnimPhAsync(SS st, string key, AState fin)
{ if(!st.PhBuilt||st.PhItems==null)return;
  st.PhHitKey=null; st.StepHint=$"FKS: h(\"{key}\") → вычисляем позицию..."; StateHasChanged(); await Task.Delay(StepMs);
  bool found=st.PhItems.Any(i=>i.Key==key);
  if(found){st.PhHitKey=key;st.StepHint=$"O(1) worst-case → найдено!";}
  else st.StepHint=$"O(1) worst-case → не найдено";
  StateHasChanged(); await Task.Delay(350); }

// ══ Tree animations ═══════════════════════════════════════════════════════════
private async Task AnimTreeSearchAsync(string slug, SS st, string key, AState fin)
{
    var path = GetTreeSearchPath(slug, st, key);
    st.AnimPath.Clear(); st.AnimEdges.Clear(); st.AnimHit=null; st.AnimMiss=null;
    for(int i=0;i<path.Count;i++)
    { if(i>0) st.AnimEdges.Add((path[i-1],path[i]));
      st.AnimPath.Add(path[i]); bool last=i==path.Count-1;
      if(last){if(fin==AState.Hit)st.AnimHit=path[i];else if(fin==AState.Miss)st.AnimMiss=path[i];}
      int cmp=last?0:string.Compare(key,path[i],StringComparison.Ordinal);
      st.StepHint=i==0?$"Корень: \"{path[i]}\""
          :cmp<0?$"\"{key}\" < \"{path[i-1]}\" → влево → \"{path[i]}\""
          :cmp>0?$"\"{key}\" > \"{path[i-1]}\" → вправо → \"{path[i]}\""
          :$"\"{key}\" == \"{path[i]}\" ✓";
      BuildTreeSvg(slug,st); StateHasChanged(); await Task.Delay(StepMs); }
    if(path.Count==0){st.StepHint="Дерево пустое";StateHasChanged();}
}

private List<string> GetTreeSearchPath(string slug, SS st, string key)
{
    if(slug=="red-black-tree")
    { var path=new List<string>(); var n=_rbtRoots.GetValueOrDefault(slug);
      while(n!=null&&!RbtIsNil(slug,n)){path.Add(n.Key);int c=string.Compare(key,n.Key,StringComparison.Ordinal);if(c==0)break;n=c<0?n.Left:n.Right;}
      return path; }
    else
    { var path=new List<string>();
      if(_tinyTrees.TryGetValue(slug,out var root)&&root!=null)
      { var n=root; while(n!=null){path.Add(n.Key);int c=string.Compare(key,n.Key,StringComparison.Ordinal);if(c==0)break;n=c<0?n.Left:n.Right;} }
      return path; }
}

// ══ Skip list animation ════════════════════════════════════════════════════════
private async Task AnimSlSearchAsync(SS st, string key, AState fin)
{ if(st.SlItems==null||st.SlItems.Count==0)return;
  var sorted=st.SlItems.OrderBy(i=>i.Key,StringComparer.Ordinal).ToList();
  st.AnimPath.Clear(); st.AnimHit=null; st.AnimMiss=null;
  int visLevels=st.SlNodeLevels.Values.Count>0?st.SlNodeLevels.Values.Max():1;
  int curIdx=-1;
  for(int lv=visLevels-1;lv>=0;lv--)
  { for(int j=curIdx+1;j<sorted.Count;j++)
    { if(!st.SlNodeLevels.TryGetValue(sorted[j].Key,out var h)||h<=lv)continue;
      st.AnimPath.Add(sorted[j].Key);
      st.StepHint=$"L{lv}: сравниваем \"{sorted[j].Key}\" vs \"{key}\"";
      BuildSlSvg(st); StateHasChanged(); await Task.Delay(StepMs);
      int cmp=string.Compare(key,sorted[j].Key,StringComparison.Ordinal);
      if(cmp==0){if(fin==AState.Hit)st.AnimHit=sorted[j].Key;else st.AnimMiss=sorted[j].Key;BuildSlSvg(st);StateHasChanged();return;}
      if(cmp>0)curIdx=j; else break; } }
  st.StepHint=fin==AState.Hit?"Найдено":"Не найдено"; BuildSlSvg(st); StateHasChanged(); }

// ══ WASM dispatch ══════════════════════════════════════════════════════════════
private async Task<bool> SlugContainsAsync(string slug, SS st, string key) => slug switch
{ "open-hashing"=>await Dtr.ChainingContainsAsync(st.WasmHandle,key), "linear-probing"=>await Dtr.LpContainsAsync(st.WasmHandle,key),
  "quadratic-probing"=>await Dtr.QpContainsAsync(st.WasmHandle,key), "double-hashing"=>DhContains(st,key),
  "robin-hood-hashing"=>RhContains(st,key), "cuckoo-hashing"=>await Dtr.CuckooContainsAsync(st.WasmHandle,key),
  "perfect-hashing"=>st.PhBuilt&&st.WasmHandle>=0&&await Dtr.PhContainsAsync(st.WasmHandle,key),
  "avl-tree"=>await Dtr.AvlContainsAsync(st.WasmHandle,key),
  "red-black-tree"=>RbtSearch(slug,_rbtRoots.GetValueOrDefault(slug),key)!=null,
  "skip-list"=>await Dtr.SlContainsAsync(st.WasmHandle,key), "cartesian-tree"=>await Dtr.TreapContainsAsync(st.WasmHandle,key),
  _=>false };

private async Task<bool> SlugAddAsync(string slug, SS st, string key, string val)
{ switch(slug)
  { case "open-hashing":      return await Dtr.ChainingAddAsync(st.WasmHandle,key,val);
    case "linear-probing":    return await Dtr.LpAddAsync(st.WasmHandle,key,val);
    case "quadratic-probing": return await Dtr.QpAddAsync(st.WasmHandle,key,val);
    case "double-hashing":    return DhAdd(st,key,val);
    case "robin-hood-hashing":return RhAdd(st,key,val);
    case "cuckoo-hashing":    return await Dtr.CuckooAddAsync(st.WasmHandle,key,val);
    case "perfect-hashing":   if(st.PhItems!.Any(p=>p.Key==key))return false; st.PhItems.Add(new DictItem(key,val)); await RebuildPhAsync(st); return true;
    case "avl-tree":          return await Dtr.AvlAddAsync(st.WasmHandle,key,val);
    case "red-black-tree":    return RbtInsertKey(slug,key,val);
    case "skip-list":         return await Dtr.SlAddAsync(st.WasmHandle,key,val);
    case "cartesian-tree":    return await Dtr.TreapAddAsync(st.WasmHandle,key,val);
    default: return false; } }

private async Task SlugInsertOrAssignAsync(string slug, SS st, string key, string val)
{ switch(slug)
  { case "open-hashing":      await Dtr.ChainingInsertOrAssignAsync(st.WasmHandle,key,val); break;
    case "linear-probing":    await Dtr.LpInsertOrAssignAsync(st.WasmHandle,key,val);       break;
    case "quadratic-probing": await Dtr.QpInsertOrAssignAsync(st.WasmHandle,key,val);       break;
    case "double-hashing":    DhInsertOrAssign(st,key,val);                                  break;
    case "robin-hood-hashing":RhInsertOrAssign(st,key,val);                                  break;
    case "cuckoo-hashing":    await Dtr.CuckooInsertOrAssignAsync(st.WasmHandle,key,val);   break;
    case "perfect-hashing":   var ex=st.PhItems!.FirstOrDefault(p=>p.Key==key); if(ex!=null)st.PhItems.Remove(ex); st.PhItems!.Add(new DictItem(key,val)); await RebuildPhAsync(st); break;
    case "avl-tree":          await Dtr.AvlInsertOrAssignAsync(st.WasmHandle,key,val);    break;
    case "red-black-tree":    RbtInsertOrAssign(slug,key,val);                             break;
    case "skip-list":         await Dtr.SlInsertOrAssignAsync(st.WasmHandle,key,val);     break;
    case "cartesian-tree":    await Dtr.TreapInsertOrAssignAsync(st.WasmHandle,key,val);  break; } }

private async Task<bool> SlugRemoveAsync(string slug, SS st, string key)
{ switch(slug)
  { case "open-hashing":      return await Dtr.ChainingRemoveAsync(st.WasmHandle,key);
    case "linear-probing":    return await Dtr.LpRemoveAsync(st.WasmHandle,key);
    case "quadratic-probing": return await Dtr.QpRemoveAsync(st.WasmHandle,key);
    case "double-hashing":    return DhRemove(st,key);
    case "robin-hood-hashing":return RhRemove(st,key);
    case "cuckoo-hashing":    return await Dtr.CuckooRemoveAsync(st.WasmHandle,key);
    case "perfect-hashing":   int idx=st.PhItems!.FindIndex(p=>p.Key==key); if(idx<0)return false; st.PhItems.RemoveAt(idx); if(st.PhItems.Count>0)await RebuildPhAsync(st);else{st.PhBuilt=false;st.WasmHandle=-1;}return true;
    case "avl-tree":          return await Dtr.AvlRemoveAsync(st.WasmHandle,key);
    case "red-black-tree":    return RbtDelete(slug,key);
    case "skip-list":         return await Dtr.SlRemoveAsync(st.WasmHandle,key);
    case "cartesian-tree":    return await Dtr.TreapRemoveAsync(st.WasmHandle,key);
    default: return false; } }

private async Task SlugClearAsync(string slug, SS st)
{ switch(slug)
  { case "open-hashing":      await Dtr.ChainingClearAsync(st.WasmHandle);   break;
    case "linear-probing":    await Dtr.LpClearAsync(st.WasmHandle);         break;
    case "quadratic-probing": await Dtr.QpClearAsync(st.WasmHandle);         break;
    case "double-hashing":    st.DhTable=NewDhTable(11);                     break;
    case "robin-hood-hashing":st.RhTable=NewRhTable(11);                     break;
    case "cuckoo-hashing":    await Dtr.CuckooClearAsync(st.WasmHandle);     break;
    case "perfect-hashing":   st.PhItems=new();st.PhBuilt=false;st.WasmHandle=-1; break;
    case "avl-tree":          await Dtr.AvlClearAsync(st.WasmHandle); _avlValues.Remove(slug); break;
    case "red-black-tree":    _rbtRoots[slug]=null;_rbtNils[slug]=new RbtNode{Color=RbColor.Black}; break;
    case "skip-list":         await Dtr.SlClearAsync(st.WasmHandle);st.SlNodeLevels.Clear();break;
    case "cartesian-tree":    await Dtr.TreapClearAsync(st.WasmHandle); break; } }

private async Task RebuildPhAsync(SS st)
{ if(st.PhHandle>=0)await Dtr.PhFreeAsync(st.PhHandle);
  if(st.PhItems!.Count==0){st.PhBuilt=false;return;}
  st.PhHandle=await Dtr.PhCreateAsync(st.PhItems!);st.WasmHandle=st.PhHandle;st.PhBuilt=st.PhHandle>=0; }

// ══ Refresh (snapshot → SS) ════════════════════════════════════════════════════
private async Task RefreshAsync(string slug)
{ var st=GetState(slug);
  switch(slug)
  { case "open-hashing":
      st.ChainBuckets=await Dtr.ChainingSnapshotAsync(st.WasmHandle);
      st.Count=st.ChainBuckets.Sum(b=>b.Chain.Count);st.Capacity=st.ChainBuckets.Count;
      st.LoadFactor=st.Capacity>0?(double)st.Count/st.Capacity:0; break;
    case "linear-probing":
      st.LpSnap=await Dtr.LpSnapshotAsync(st.WasmHandle);
      st.Count=st.LpSnap.Count;st.Capacity=st.LpSnap.Capacity;st.LoadFactor=st.LpSnap.LoadFactor; break;
    case "quadratic-probing":
      st.QpSnap=await Dtr.QpSnapshotAsync(st.WasmHandle);
      st.Count=st.QpSnap.Count;st.Capacity=st.QpSnap.Capacity;st.LoadFactor=st.QpSnap.LoadFactor; break;
    case "double-hashing":
      st.Count=st.DhTable!.Count(s=>s.State==DhS.Occupied);st.Capacity=st.DhTable.Length;
      st.LoadFactor=st.Capacity>0?(double)st.Count/st.Capacity:0; break;
    case "robin-hood-hashing":
      st.Count=st.RhTable!.Count(s=>s.State==RhS.Occupied);st.Capacity=st.RhTable.Length;
      st.LoadFactor=st.Capacity>0?(double)st.Count/st.Capacity:0; break;
    case "cuckoo-hashing":
      var ck=await Dtr.CuckooSnapshotAsync(st.WasmHandle);
      st.Count=ck.Count;st.LoadFactor=ck.LoadFactor;st.Capacity=CkNextPow2(Math.Max(ck.Count,1)*2,8);
      CkRebuildTables(st,ck); break;
    case "perfect-hashing":
      if(st.PhBuilt&&st.WasmHandle>=0){st.PhItems=await Dtr.PhSnapshotAsync(st.WasmHandle);st.Count=st.PhItems.Count;}else st.Count=0; break;
    case "avl-tree":
      st.Count=await Dtr.AvlCountAsync(st.WasmHandle);st.Height=await Dtr.AvlHeightAsync(st.WasmHandle);
      var avlItems=await Dtr.AvlSnapshotAsync(st.WasmHandle);
      if(!_avlValues.ContainsKey(slug))_avlValues[slug]=new();
      foreach(var i in avlItems)_avlValues[slug][i.Key]=i.Value;
      _tinyTrees[slug]=TinyBuild(avlItems,0,avlItems.Count-1);
      BuildTreeSvg(slug,st); break;
    case "red-black-tree":
      st.Count=RbtCount(slug);st.Height=RbtHeight(slug);BuildTreeSvg(slug,st); break;
    case "skip-list":
      st.Count=await Dtr.SlCountAsync(st.WasmHandle);st.Height=await Dtr.SlMaxLevelAsync(st.WasmHandle);st.MaxLevel=st.Height;
      st.SlItems=await Dtr.SlSnapshotAsync(st.WasmHandle);
      foreach(var item in st.SlItems)if(!st.SlNodeLevels.ContainsKey(item.Key))st.SlNodeLevels[item.Key]=SlGenLevel(st.MaxLevel);
      var dead=st.SlNodeLevels.Keys.Where(k=>!st.SlItems.Any(i=>i.Key==k)).ToList();foreach(var k in dead)st.SlNodeLevels.Remove(k);
      BuildSlSvg(st); break;
    case "cartesian-tree":
      st.Count=await Dtr.TreapCountAsync(st.WasmHandle);st.Height=await Dtr.TreapHeightAsync(st.WasmHandle);
      var tdto=await Dtr.TreapSnapshotAsync(st.WasmHandle);
      _tinyTrees[slug]=tdto==null?null:TinyFromTreap(tdto);
      st.TreeSvg=RenderTreapSvg(st,tdto); break; } }

// ══ Tiny tree helpers for animation traversal ══════════════════════════════════
private class TinyNode { public string Key=""; public TinyNode? Left,Right; }
private static TinyNode? TinyBuild(List<DictItem> s,int lo,int hi){if(lo>hi)return null;int m=(lo+hi)/2;return new TinyNode{Key=s[m].Key,Left=TinyBuild(s,lo,m-1),Right=TinyBuild(s,m+1,hi)};}
private static TinyNode? TinyFromTreap(TreapNodeDto d)=>new TinyNode{Key=d.Key,Left=d.Left!=null?TinyFromTreap(d.Left):null,Right=d.Right!=null?TinyFromTreap(d.Right):null};

// ══ SVG builders ══════════════════════════════════════════════════════════════
private void BuildTreeSvg(string slug, SS st)
{ if(slug=="avl-tree")      {st.TreeSvg=RenderAvlSvg(slug,st);  return;}
  if(slug=="red-black-tree"){st.TreeSvg=RenderRbtSvg(slug,st);  return;}
  if(slug=="cartesian-tree"){/* treap: nothing here, done in refresh */      return;} }

// ─── AVL ────────────────────────────────────────────────────────────────────
private class AvlVN{public string Key="",Value="";public double X,Y;public int D;public AvlVN? L,R;}
private static AvlVN? AvlVBuild(List<DictItem> s,int lo,int hi,int d){if(lo>hi)return null;int m=(lo+hi)/2;return new AvlVN{Key=s[m].Key,Value=s[m].Value,D=d,L=AvlVBuild(s,lo,m-1,d+1),R=AvlVBuild(s,m+1,hi,d+1)};}
private static void AvlVPos(AvlVN? n,ref int r){if(n==null)return;AvlVPos(n.L,ref r);n.X=65+r*130;n.Y=46+n.D*82;r++;AvlVPos(n.R,ref r);}

private string RenderAvlSvg(string slug, SS st)
{ if(!_avlValues.TryGetValue(slug,out var vm)||vm==null)vm=new();
  if(!_tinyTrees.TryGetValue(slug,out var tiny)||tiny==null)return EMPTY_SVG;
  var keys=new List<string>(); void IO(TinyNode? n){if(n==null)return;IO(n.Left);keys.Add(n.Key);IO(n.Right);} IO(tiny);
  var items=keys.Select(k=>new DictItem(k,vm.TryGetValue(k,out var v)?v:"")).ToList();
  var root=AvlVBuild(items,0,items.Count-1,0); int rank=0; AvlVPos(root,ref rank);
  var all=new List<AvlVN>(); void C(AvlVN? n){if(n==null)return;all.Add(n);C(n.L);C(n.R);} C(root);
  if(all.Count==0)return EMPTY_SVG;
  double W=all.Max(n=>n.X)+100,H=all.Max(n=>n.Y)+55;
  var sb=new System.Text.StringBuilder();
  sb.Append($"<div class='cmp-tree-wrap'><svg viewBox='0 0 {F(W)} {F(H)}' width='{F(W)}' height='{F(H)}' xmlns='http://www.w3.org/2000/svg' style='display:block'><rect x='0' y='0' width='{F(W)}' height='{F(H)}' fill='#fff'/>");
  void DE(AvlVN? n){if(n==null)return;
    if(n.L!=null){bool on=st.AnimEdges.Contains((n.Key,n.L.Key));sb.Append($"<line x1='{F(n.X)}' y1='{F(n.Y)}' x2='{F(n.L.X)}' y2='{F(n.L.Y)}' stroke='{(on?"#cc8800":"#9aafcc")}' stroke-width='{(on?"2.5":"1.5")}'/>");DE(n.L);}
    if(n.R!=null){bool on=st.AnimEdges.Contains((n.Key,n.R.Key));sb.Append($"<line x1='{F(n.X)}' y1='{F(n.Y)}' x2='{F(n.R.X)}' y2='{F(n.R.Y)}' stroke='{(on?"#cc8800":"#9aafcc")}' stroke-width='{(on?"2.5":"1.5")}'/>");DE(n.R);}} DE(root);
  foreach(var n in all)
  { AState ns=n.Key==st.AnimHit?AState.Hit:n.Key==st.AnimMiss?AState.Miss:st.AnimPath.Contains(n.Key)?AState.Scanning:AState.Normal;
    (string f,string s,string sw,string tf,string vf)=ns switch{AState.Hit=>("#ddffdd","#00aa44","2","#004400","#006622"),AState.Miss=>("#ffe0e0","#cc3333","2","#440000","#881111"),AState.Scanning=>("#fffacc","#cc8800","2","#553300","#885500"),_=>("#eef2f7","#8899aa","1","#1a2533","#445566")};
    double rx=n.X-60,ry=n.Y-21;
    sb.Append($"<rect x='{F(rx)}' y='{F(ry)}' width='120' height='42' rx='3' fill='{f}' stroke='{s}' stroke-width='{sw}'/>");
    sb.Append($"<text x='{F(n.X)}' y='{F(n.Y-6)}' text-anchor='middle' font-family='monospace' font-size='11' font-weight='bold' fill='{tf}'>{Enc(Trunc(n.Key,14))}</text>");
    sb.Append($"<line x1='{F(rx+4)}' y1='{F(n.Y+1)}' x2='{F(rx+116)}' y2='{F(n.Y+1)}' stroke='#ccc' stroke-width='0.5'/>");
    sb.Append($"<text x='{F(n.X)}' y='{F(n.Y+13)}' text-anchor='middle' font-family='monospace' font-size='10' fill='{vf}'>{Enc(Trunc(n.Value,14))}</text>"); }
  sb.Append("</svg></div>"); return sb.ToString(); }

// ─── RBT ────────────────────────────────────────────────────────────────────
private string RenderRbtSvg(string slug, SS st)
{ var root=_rbtRoots.GetValueOrDefault(slug); if(RbtIsNil(slug,root))return EMPTY_SVG;
  var vis=new List<(string Key,string Val,RbColor C,double X,double Y)>();
  var edges=new List<(double x1,double y1,double x2,double y2,string fk,string tk)>();
  var nils=new List<(double X,double Y)>(); var nilE=new List<(double x1,double y1,double x2,double y2)>();
  int rank=0;
  void Pos(RbtNode? n,int d){if(RbtIsNil(slug,n))return;Pos(n!.Left,d+1);vis.Add((n.Key,n.Value,n.Color,65+rank*130,46+d*82));rank++;Pos(n.Right,d+1);}
  Pos(root,0);
  void CE(RbtNode? n){if(RbtIsNil(slug,n))return;var nv=vis.FirstOrDefault(v=>v.Key==n!.Key);
    if(!RbtIsNil(slug,n!.Left)){var l=vis.FirstOrDefault(v=>v.Key==n.Left!.Key);if(l.Key!=null)edges.Add((nv.X,nv.Y,l.X,l.Y,n.Key,n.Left!.Key));CE(n.Left);}
    if(!RbtIsNil(slug,n.Right)){var r=vis.FirstOrDefault(v=>v.Key==n.Right!.Key);if(r.Key!=null)edges.Add((nv.X,nv.Y,r.X,r.Y,n.Key,n.Right!.Key));CE(n.Right);}} CE(root);
  void CN(RbtNode? n){if(RbtIsNil(slug,n))return;var nv=vis.FirstOrDefault(v=>v.Key==n!.Key);
    if(RbtIsNil(slug,n!.Left)){double nx=nv.X-32,ny=nv.Y+82;nils.Add((nx,ny));nilE.Add((nv.X,nv.Y,nx,ny));}else CN(n.Left);
    if(RbtIsNil(slug,n.Right)){double nx=nv.X+32,ny=nv.Y+82;nils.Add((nx,ny));nilE.Add((nv.X,nv.Y,nx,ny));}else CN(n.Right);} CN(root);
  double W=vis.Count*130,H=46*2+(RbtHeight(slug)+1)*82+20;
  var sb=new System.Text.StringBuilder();
  sb.Append($"<div class='cmp-tree-wrap'><svg viewBox='0 0 {F(W)} {F(H)}' width='{F(W)}' height='{F(H)}' xmlns='http://www.w3.org/2000/svg' style='display:block'><rect x='0' y='0' width='{F(W)}' height='{F(H)}' fill='#fff'/>");
  sb.Append("<rect x='4' y='4' width='14' height='8' rx='1' fill='#e8edf5' stroke='#445566' stroke-width='1'/><text x='21' y='12' font-family='monospace' font-size='9' fill='#445566'>Чёрный</text>");
  sb.Append("<rect x='74' y='4' width='14' height='8' rx='1' fill='#fde8e8' stroke='#cc3333' stroke-width='1'/><text x='91' y='12' font-family='monospace' font-size='9' fill='#cc3333'>Красный</text>");
  sb.Append("<rect x='148' y='4' width='14' height='8' rx='1' fill='#e8edf5' stroke='#445566' stroke-width='1'/><text x='165' y='12' font-family='monospace' font-size='9' fill='#445566'>NIL</text>");
  foreach(var e in edges){bool on=st.AnimEdges.Contains((e.fk,e.tk));sb.Append($"<line x1='{F(e.x1)}' y1='{F(e.y1)}' x2='{F(e.x2)}' y2='{F(e.y2)}' stroke='{(on?"#cc8800":"#9aafcc")}' stroke-width='{(on?"2.5":"1.5")}' stroke-dasharray='{(on?"6,3":"none")}'/>");}
  foreach(var e in nilE)sb.Append($"<line x1='{F(e.x1)}' y1='{F(e.y1)}' x2='{F(e.x2)}' y2='{F(e.y2)}' stroke='#8899aa' stroke-width='1' stroke-dasharray='4,3'/>");
  foreach(var nl in nils){double rx=nl.X-28,ry=nl.Y-15;sb.Append($"<rect x='{F(rx)}' y='{F(ry)}' width='56' height='30' rx='3' fill='#e8edf5' stroke='#445566' stroke-width='1'/><text x='{F(nl.X)}' y='{F(nl.Y+5)}' text-anchor='middle' font-family='monospace' font-size='11' font-weight='bold' fill='#445566'>NIL</text>");}
  foreach(var n in vis)
  { AState ns=n.Key==st.AnimHit?AState.Hit:n.Key==st.AnimMiss?AState.Miss:st.AnimPath.Contains(n.Key)?AState.Scanning:AState.Normal;
    string f,s,sw,tf,vf;
    if(ns==AState.Hit){f="#ddffdd";s="#00aa44";sw="2";tf="#004400";vf="#006622";}
    else if(ns==AState.Miss){f="#ffe0e0";s="#cc3333";sw="2";tf="#440000";vf="#881111";}
    else if(ns==AState.Scanning){f="#fffacc";s="#cc8800";sw="2";tf="#553300";vf="#885500";}
    else if(n.C==RbColor.Red){f="#fde8e8";s="#cc3333";sw="1.5";tf="#5c1010";vf="#8b1919";}
    else{f="#e8edf5";s="#445566";sw="1";tf="#1a2533";vf="#445566";}
    double rx=n.X-60,ry=n.Y-21;
    sb.Append($"<rect x='{F(rx)}' y='{F(ry)}' width='120' height='42' rx='3' fill='{f}' stroke='{s}' stroke-width='{sw}'/>");
    sb.Append($"<text x='{F(n.X)}' y='{F(n.Y-6)}' text-anchor='middle' font-family='monospace' font-size='11' font-weight='bold' fill='{tf}'>{Enc(Trunc(n.Key,14))}</text>");
    sb.Append($"<line x1='{F(rx+5)}' y1='{F(n.Y+1)}' x2='{F(rx+115)}' y2='{F(n.Y+1)}' stroke='#ccc' stroke-width='0.5'/>");
    sb.Append($"<text x='{F(n.X)}' y='{F(n.Y+13)}' text-anchor='middle' font-family='monospace' font-size='10' fill='{vf}'>{Enc(Trunc(n.Val,14))}</text>"); }
  sb.Append("</svg></div>"); return sb.ToString(); }

// ─── Treap ──────────────────────────────────────────────────────────────────
private class TreapVN{public string Key="",Value="";public long Prio;public double X,Y;public int D;public TreapVN? L,R;}
private static TreapVN? TDtoToV(TreapNodeDto? d,int dep=0){if(d==null)return null;return new TreapVN{Key=d.Key,Value=d.Value,Prio=d.Priority,D=dep,L=TDtoToV(d.Left,dep+1),R=TDtoToV(d.Right,dep+1)};}
private static void TVPos(TreapVN? n,ref int r){if(n==null)return;TVPos(n.L,ref r);n.X=65+r*130;n.Y=46+n.D*82;r++;TVPos(n.R,ref r);}

private string RenderTreapSvg(SS st, TreapNodeDto? dto)
