        _busy = false; StateHasChanged();
    }

    private void ClearLog() => _log.Clear();

    // ── Animation ─────────────────────────────────────────────────────────────
    private async Task AnimateProbe(List<int> path, bool hit, HashSet<int> swapSlots)
    {
        _lastProbePath  = new List<int>(path);
        _lastSwapSlots  = swapSlots;
        _lastProbeHit   = hit;
        _lastProbeSteps = path.Count;

        for (int pi = 0; pi < path.Count; pi++)
        {
            _probeCursor = path[pi];
            string animCls = (pi == path.Count - 1 && hit) ? "lp-hit"
                : (pi == 0) ? "lp-probe"
                : swapSlots.Contains(path[pi]) ? "rh-steal"
                : "lp-collision";
            _slotAnimMap[path[pi]] = animCls;
            StateHasChanged();
            await Task.Delay(StepMs);
        }
        _probeCursor = -1;
        StateHasChanged();
        await Task.Delay(500);
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    private string GetSlotAnimCls(int idx)
    {
        if (_slotAnimMap.TryGetValue(idx, out var animCls))
            return animCls;
        return _table[idx].State switch
        {
            RhSlotState.Empty    => "lp-empty",
            RhSlotState.Occupied => "lp-occ",
            _                    => ""
        };
    }

    private void ClearAnim()
    {
        _probeCursor = -1;
        _slotAnimMap.Clear();
        _lastProbePath.Clear();
        _lastSwapSlots.Clear();
    }

    private void SetStatus(string msg, string cls, string icon)
    {
        _status = msg; _statusCls = cls; _statusIcon = icon;
    }

    private void AddLog(string text, string cls)
    {
        _log.Add(new LogEntry { Text = text, Cls = cls });
        if (_log.Count > 50) _log.RemoveAt(0);
    }

    private static string TruncStr(string s, int max) =>
        s.Length <= max ? s : s[..max] + "…";

    private static int NextPrime(int n)
    {
        if (n < 2) return 2;
        if (n % 2 == 0) n++;
        while (!IsPrime(n)) n += 2;
        return n;
    }

    private static bool IsPrime(int n)
    {
        if (n < 2) return false;
        if (n == 2) return true;
        if (n % 2 == 0) return false;
        for (int i = 3; i * i <= n; i += 2)
            if (n % i == 0) return false;
        return true;
    }

    private async Task BulkInsertAsync(List<(string Key, string Value)> pairs)
    {
        _busy = true; ClearAnim(); _lastSwapEvents.Clear();
        int added = 0;
        foreach (var (k, v) in pairs)
        {
            if (LoadFactor >= 0.70) MaybeResize();
            var (at, _) = RhInsert(k, v);
            if (at >= 0) added++;
        }
        SetStatus($"Сгенерировано: добавлено {added} из {pairs.Count} · MaxPSL={MaxPsl} · AvgPSL={AvgPsl:F2}", "status-ok", "✓");
        AddLog($"Генерация: +{added}, MaxPSL={MaxPsl}, AvgPSL={AvgPsl:F2}", "log-ok");
        _busy = false;
        StateHasChanged();
    }
}
