@page "/demo/rh"
@inject DictoriumJsService Dtr

<PageTitle>RobinHoodDictionary — Демо — Dictorium</PageTitle>

<div class="page-wrap">

    <div class="breadcrumb">
        <a href="">Обзор</a>
        <span class="bc-sep">›</span>
        <span class="bc-now">RobinHoodDictionary [LIVE]</span>
    </div>

    <div class="struct-head-bar">
        <div class="struct-issue-num" style="color:var(--acc-g)">
            dtr::RobinHoodDictionary&lt;string, string&gt; — симуляция через C# + WASM
        </div>
        <h1 class="struct-h1">Хэширование Робин Гуда</h1>
        <div class="struct-en">RobinHoodDictionary.h · открытая адресация · линейное пробирование + PSL-своп</div>
        <p class="struct-description">
            Оптимизация линейного пробирования: при вставке новый элемент сравнивает своё
            <strong>PSL (Probe Sequence Length)</strong> — число шагов от «домашнего» слота — с PSL
            элемента в текущем слоте. Если PSL нового &gt; PSL занятого, происходит <em>«кража у богатого»</em>:
            новый элемент занимает слот, а вытесненный продолжает поиск с позиции. Это выравнивает
            распределение PSL и <strong>снижает дисперсию</strong> до минимума, даже при высоком α.
        </p>
        <div class="struct-tags">
            <span class="s-tag">ContainsKey O(1) avg</span>
            <span class="s-tag">Add O(1) avg</span>
            <span class="s-tag">Remove O(1) avg</span>
            <span class="s-tag">α &lt; 0.9 допустимо</span>
            <span class="s-tag">PSL дисперсия минимальна</span>
            <span class="s-tag">h(k) = djb2(k) mod m</span>
            @if (_wasmReady)
            {
                <span class="s-tag" style="color:var(--acc-g);border-color:var(--acc-g)">● WASM готов</span>
            }
            else
            {
                <span class="s-tag" style="color:var(--acc-r)">○ Загрузка WASM...</span>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_status))
    {
        <div class="demo-status @_statusCls">
            <strong>@_statusIcon</strong>&nbsp; @_status
        </div>
    }

    @if (!_wasmReady)
    {
        <div class="comp-hint">Загрузка WebAssembly модуля Dictorium...</div>
    }
    else
    {
        <div class="demo-layout">

            <!-- ── Controls ── -->
            <div class="demo-controls">

                <div class="ctrl-section">
                    <div class="ctrl-section-title">Ключ (Key)</div>
                    <input class="search-input" style="width:100%;"
                           @bind="_keyInput" @bind:event="oninput"
                           placeholder="apple"
                           disabled="@_busy" />
                    <div class="ctrl-section-title" style="margin-top:6px;">Значение (Value)</div>
                    <input class="search-input" style="width:100%;margin-bottom:0;"
                           @bind="_valInput" @bind:event="oninput"
                           placeholder="яблоко"
                           disabled="@_busy" />
                </div>

                <!-- Hash + PSL preview -->
                @if (!string.IsNullOrWhiteSpace(_keyInput))
                {
                    var pk = _keyInput.Trim();
                    int ph = RhHash(pk, _table.Length);
                    int curPsl = ComputeCurrentPsl(pk);
                    <div class="dh-hash-preview">
                        <div class="dh-preview-title">Хэш для «@TruncStr(pk, 10)»</div>
                        <div class="dh-preview-row">
                            <span class="dh-fn">h</span>
                            <span class="dh-fn-formula">djb2 mod @_table.Length</span>
                            <span class="dh-fn-val" style="color:var(--acc-b)">= @ph</span>
                        </div>
                        <div class="dh-preview-formula">
                            home = @ph &nbsp;·&nbsp; probe: @ph → @((ph+1)%_table.Length) → @((ph+2)%_table.Length) …
                        </div>
                        @if (curPsl >= 0)
                        {
                            <div class="rh-preview-psl">
                                Текущий PSL в таблице: <strong style="color:var(--acc-g)">@curPsl</strong>
                            </div>
                        }
                    </div>
                }

                <div class="ctrl-ops">
                    <div class="op-hint-row">
                        <button class="btn-op btn-search" @onclick="DoContains"
                                disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput))">
                            ▶ ContainsKey(key)
                        </button>
                        <span class="op-hint-icon @(_activeDemoTip=="contains"?"active":"")" @onclick='()=>ToggleDemoTip("contains")'>i</span>
                    </div>
                    <div class="op-hint-row">
                        <button class="btn-op btn-search" @onclick="DoGet"
                                disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput))">
                            ▶ TryGetValue(key)
                        </button>
                        <span class="op-hint-icon @(_activeDemoTip=="get"?"active":"")" @onclick='()=>ToggleDemoTip("get")'>i</span>
                    </div>
                    <div class="op-hint-row">
                        <button class="btn-op btn-add" @onclick="DoAdd"
                                disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput) || string.IsNullOrWhiteSpace(_valInput))">
                            + Add(key, value)
                        </button>
                        <span class="op-hint-icon @(_activeDemoTip=="add"?"active":"")" @onclick='()=>ToggleDemoTip("add")'>i</span>
                    </div>
                    <div class="op-hint-row">
                        <button class="btn-op btn-add" @onclick="DoInsertOrAssign"
                                disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput) || string.IsNullOrWhiteSpace(_valInput))">
                            ± InsertOrAssign(key, value)
                        </button>
                        <span class="op-hint-icon @(_activeDemoTip=="ioa"?"active":"")" @onclick='()=>ToggleDemoTip("ioa")'>i</span>
                    </div>
                    <div class="op-hint-row">
                        <button class="btn-op btn-remove" @onclick="DoRemove"
                                disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput))">
                            − Remove(key)
                        </button>
                        <span class="op-hint-icon @(_activeDemoTip=="remove"?"active":"")" @onclick='()=>ToggleDemoTip("remove")'>i</span>
                    </div>
                    <div class="op-hint-row">
                        <button class="btn-op btn-clear" @onclick="DoClear" disabled="@_busy">
                            ⊘ Clear()
                        </button>
                        <span class="op-hint-icon @(_activeDemoTip=="clear"?"active":"")" @onclick='()=>ToggleDemoTip("clear")'>i</span>
                    </div>
                </div>

                <DemoOpHints ActiveTip="@_activeDemoTip" OnToggle="@((id) => { _activeDemoTip = id; StateHasChanged(); })" />

                <!-- Stats -->
                <div class="ctrl-info">
                    <div class="ctrl-info-row">
                        <span>Count</span>
                        <span class="ctrl-info-val">@_count</span>
                    </div>
                    <div class="ctrl-info-row">
                        <span>Capacity</span>
                        <span class="ctrl-info-val">@_table.Length</span>
                    </div>
                    <div class="ctrl-info-row">
                        <span>Загрузка (α)</span>
                        <span class="ctrl-info-val">@LoadFactor.ToString("F2")</span>
                    </div>
                    <div class="ctrl-info-row">
                        <span>Max PSL</span>
                        <span class="ctrl-info-val" style="color:var(--acc-r)">@MaxPsl</span>
                    </div>
                    <div class="ctrl-info-row">
                        <span>Avg PSL</span>
                        <span class="ctrl-info-val" style="color:var(--acc-b)">@AvgPsl.ToString("F2")</span>
                    </div>
                    <div class="ctrl-info-row">
                        <span>Свопов вставки</span>
                        <span class="ctrl-info-val">@(_lastSwapCount > 0 ? _lastSwapCount.ToString() : "—")</span>
                    </div>
                    <div class="ctrl-info-row">
                        <span>Шагов probe</span>
                        <span class="ctrl-info-val">@(_lastProbeSteps > 0 ? _lastProbeSteps.ToString() : "—")</span>
                    </div>
                    <div class="ctrl-info-row">
                        <span>Результат</span>
                        <span class="ctrl-info-val">@_result</span>
                    </div>
                </div>

                <!-- Legend -->
                <div class="ctrl-legend">
                    <div class="legend-title">Легенда</div>
                    <div class="legend-row">
                        <span class="lp-legend-dot lp-dot-empty"></span> Пустой слот
                    </div>
                    <div class="legend-row">
                        <span class="lp-legend-dot lp-dot-occ"></span> Занятый слот
                    </div>
                    <div class="legend-row">
                        <span class="lp-legend-dot lp-dot-probe"></span> Пробируется
                    </div>
                    <div class="legend-row">
                        <span class="lp-legend-dot lp-dot-col"></span> Коллизия (пропуск)
                    </div>
                    <div class="legend-row" style="display:flex;align-items:center;gap:6px;">
                        <span class="rh-psl-badge rh-psl-0" style="min-width:20px;">0</span>
                        <span class="rh-psl-badge rh-psl-1" style="min-width:20px;">1</span>
                        <span class="rh-psl-badge rh-psl-2" style="min-width:20px;">2</span>
                        <span class="rh-psl-badge rh-psl-hi" style="min-width:20px;">3+</span>
                        <span style="font-size:10px;color:var(--text-3)">PSL</span>
                    </div>
                    <div class="legend-row" style="font-size:10px;color:var(--text-3);margin-top:4px;">
                        <span style="border-left:3px solid #0044cc;padding-left:4px;">home</span>
                        &nbsp;— домашний слот ключа
                    </div>
                    <div class="legend-row" style="font-size:10px;color:#aa6600;margin-top:2px;">
                        ⇄ STEAL — кража слота у «богатого»
                    </div>
                </div>

                <!-- Quick load -->
                <div class="ctrl-section">
                    <div class="ctrl-section-title">Быстрая загрузка</div>
                    <button class="btn-op" @onclick="LoadSample" disabled="@_busy">
                        Загрузить пример
                    </button>
                </div>

                <BulkGeneratePanel Disabled="@_busy" OnInsert="BulkInsertAsync" />

            </div>

            <!-- ── Main visualisation ── -->
            <div class="demo-main">

                <!-- Robin Hood principle bar -->
                <div class="rh-principle-bar">
                    <div class="rh-principle-title">Принцип Робин Гуда</div>
                    <div style="font-size:11px;color:var(--text-2);margin-bottom:6px;">
                        При вставке в слот [i] сравниваем PSL нового элемента с PSL занятого:
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;font-size:11px;font-family:var(--font-mono);">
                        <span>PSL<sub>new</sub></span>
                        <span style="color:var(--acc-r);font-weight:700;">&gt;</span>
                        <span>PSL<sub>cur</sub></span>
                        <span style="color:var(--text-3)">⟹</span>
                        <span class="rh-poor">кража у «богатого»</span>
                        <span style="color:var(--text-3)">⇄ swap</span>
                        <span style="color:var(--text-3);font-size:10px;">(cur → вытеснен, продолжает поиск)</span>
                    </div>
                    <div style="display:flex;align-items:center;gap:8px;font-size:11px;font-family:var(--font-mono);margin-top:4px;">
                        <span>PSL<sub>new</sub></span>
                        <span style="color:var(--acc-g);font-weight:700;">≤</span>
                        <span>PSL<sub>cur</sub></span>
                        <span style="color:var(--text-3)">⟹</span>
                        <span class="rh-rich">«богатый» остаётся</span>
                        <span style="color:var(--text-3);font-size:10px;">(new продолжает поиск)</span>
                    </div>
                    <!-- Last operation swap events -->
                    @if (_lastSwapEvents.Count > 0)
                    {
                        <div style="margin-top:8px;border-top:1px solid var(--border);padding-top:6px;">
                            <div style="font-size:10px;color:var(--text-3);margin-bottom:4px;">Свопы последней вставки:</div>
                            @foreach (var ev in _lastSwapEvents)
                            {
                                <div class="rh-swap-event">
                                    <span class="rh-swap-icon">⇄</span>
                                    <span>@ev</span>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Hash table visualization -->
                <div class="viz-section">
                    <div class="viz-section-head">
                        <span class="viz-section-title">Хэш-таблица — Робин Гуд</span>
                        <span class="viz-section-info">
                            @_table.Length слотов · @_count элементов
                        </span>
                    </div>

                    <div class="lp-table-wrap" style="position:relative;padding-left:16px;">
                        @for (int si = 0; si < _table.Length; si++)
                        {
                            var slot = _table[si];
                            string rowCls = GetSlotAnimCls(si);
                            bool isHome = slot.State == RhSlotState.Occupied && slot.HomeSlot == si;
                            bool isCursor = _probeCursor == si;

                            <div class="lp-slot-row @rowCls @(isHome ? "lp-home" : "")">

                                @if (isCursor)
                                {
                                    <div class="lp-probe-arrow">▶</div>
                                }

                                <div class="lp-slot-idx">[@si]</div>

                                <div class="lp-slot-state">
                                    @switch (slot.State)
                                    {
                                        case RhSlotState.Empty:
                                            <span class="lp-state-empty">○</span>
                                            break;
                                        case RhSlotState.Occupied:
                                            <span class="lp-state-occ">●</span>
                                            break;
                                    }
                                </div>

                                <!-- PSL badge -->
                                @if (slot.State == RhSlotState.Occupied)
                                {
                                    string pslCls = slot.Psl switch
                                    {
                                        0 => "rh-psl-0",
                                        1 => "rh-psl-1",
                                        2 => "rh-psl-2",
                                        3 => "rh-psl-3",
                                        _ => "rh-psl-hi"
                                    };
                                    <div class="rh-psl-badge @pslCls" title="PSL=@slot.Psl (home=@slot.HomeSlot)">
                                        @slot.Psl
                                    </div>
                                }
                                else
                                {
                                    <div style="min-width:28px;"></div>
                                }

                                <div class="lp-slot-body">
                                    @if (isHome && slot.State == RhSlotState.Occupied)
                                    {
                                        <span class="lp-home-badge">home</span>
                                    }
                                    @switch (slot.State)
                                    {
                                        case RhSlotState.Empty:
                                            <span class="lp-slot-null">— пусто —</span>
                                            break;
                                        case RhSlotState.Occupied:
                                            <span class="lp-slot-key" title="@slot.Key">@TruncStr(slot.Key, 12)</span>
                                            <span class="lp-slot-sep">→</span>
                                            <span class="lp-slot-val" title="@slot.Value">@TruncStr(slot.Value, 12)</span>
                                            break;
                                    }
                                </div>

                                @if (slot.State == RhSlotState.Occupied && slot.HomeSlot >= 0 && slot.HomeSlot != si)
                                {
                                    <div class="lp-slot-hash">h=@slot.HomeSlot</div>
                                }

                            </div>
                        }
                    </div>

                    @if (_count == 0)
                    {
                        <div style="text-align:center;padding:8px;font-family:var(--font-ui);
                                    font-size:11px;color:var(--text-3);border:1px dotted var(--border);
                                    margin-bottom:6px;">
                            Таблица инициализирована · все @_table.Length слотов пусты
                        </div>
                    }

                    <!-- Stats bar -->
                    <div class="lp-stats-bar">
                        <div class="lp-stat-item">
                            <span class="lp-stat-label">Загрузка α = n / cap</span>
                            <div class="lp-load-bar-wrap">
                                <div class="lp-load-bar @LoadBarWarnCls" style="@LoadBarStyle"></div>
                                <span class="lp-load-val">@LoadFactor.ToString("F2")</span>
                            </div>
                        </div>
                        @if (_lastProbePath.Count > 0)
                        {
                            <div class="lp-stat-item">
                                <span class="lp-stat-label">Probe sequence последней операции</span>
                                <div class="lp-probe-trail">
                                    @for (int pi = 0; pi < _lastProbePath.Count; pi++)
                                    {
                                        int slotIdx = _lastProbePath[pi];
                                        bool wasSwap = _lastSwapSlots.Contains(slotIdx);
                                        string trailCls = pi == 0 ? "lp-trail-home"
                                            : pi == _lastProbePath.Count - 1 && _lastProbeHit ? "lp-trail-hit"
                                            : wasSwap ? "lp-trail-del"
                                            : "lp-trail-col";
                                        @if (pi > 0) { <span class="lp-trail-arrow">→</span> }
                                        <span class="lp-trail-slot @trailCls"
                                              title="@(wasSwap ? "STEAL" : $"step {pi}")">
                                            [@slotIdx]@(wasSwap ? "⇄" : "")
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <!-- PSL distribution chart -->
                    @if (_count > 0)
                    {
                        var pslDist = GetPslDistribution();
                        int maxCount = pslDist.Values.DefaultIfEmpty(0).Max();
                        <div class="rh-psl-chart">
                            <div class="rh-psl-chart-title">Распределение PSL (Probe Sequence Length)</div>
                            <div class="rh-psl-bars">
                                @for (int p = 0; p <= Math.Max(MaxPsl, 3); p++)
                                {
                                    int cnt = pslDist.GetValueOrDefault(p, 0);
                                    int barH = maxCount > 0 ? (int)(cnt * 44.0 / maxCount) : 0;
                                    string barColor = p switch
                                    {
                                        0 => "#22aa44",
                                        1 => "#3388cc",
                                        2 => "#cc9900",
                                        3 => "#cc6600",
                                        _ => "#cc2200"
                                    };
                                    <div class="rh-psl-bar-col">
                                        <div style="font-size:9px;color:var(--text-3);font-family:var(--font-mono);">@cnt</div>
                                        <div class="rh-psl-bar-fill"
                                             style="height:@(barH)px;background:@barColor;">
                                        </div>
                                        <div class="rh-psl-bar-label">@p</div>
                                    </div>
                                }
                            </div>
                            <div class="rh-stats-inline" style="margin-top:8px;">
                                <div class="rh-stat-chip">Max PSL: <span>@MaxPsl</span></div>
                                <div class="rh-stat-chip">Avg PSL: <span>@AvgPsl.ToString("F2")</span></div>
                                <div class="rh-stat-chip">Элементов: <span>@_count</span></div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Operation Log -->
                <div class="viz-section" style="margin-top:8px;">
                    <div class="viz-section-head">
                        <span class="viz-section-title">Лог операций</span>
                        <button class="btn-op btn-clear"
                                style="padding:1px 6px;font-size:10px;width:auto;"
                                @onclick="ClearLog">
                            очистить
                        </button>
                    </div>
                    <div class="demo-log">
                        @if (_log.Count == 0)
                        {
                            <div class="log-line log-miss">// нет операций</div>
                        }
                        else
                        {
                            @for (int li = _log.Count - 1; li >= 0; li--)
                            {
                                <div class="log-line @_log[li].Cls">@_log[li].Text</div>
                            }
                        }
                    </div>
                </div>

            </div>
        </div>
    }
</div>

@code {
    // ── Slot model ─────────────────────────────────────────────────────────────
    private enum RhSlotState { Empty, Occupied }

    private class RhSlot
    {
        public RhSlotState State    { get; set; } = RhSlotState.Empty;
        public string      Key      { get; set; } = string.Empty;
        public string      Value    { get; set; } = string.Empty;
        public int         HomeSlot { get; set; } = -1;
        public int         Psl      { get; set; } = 0;   // Probe Sequence Length
    }

    // ── State ─────────────────────────────────────────────────────────────────
    private string? _activeDemoTip = null;
    private void ToggleDemoTip(string id) => _activeDemoTip = _activeDemoTip == id ? null : id;

    private bool _wasmReady;
    private bool _busy;

    private RhSlot[] _table = new RhSlot[11];
    private int      _count;

    // Animation state
    private int          _probeCursor   = -1;
    private List<int>    _lastProbePath = new();
    private HashSet<int> _lastSwapSlots = new();
    private bool         _lastProbeHit;
    private int          _lastProbeSteps;
    private int          _lastSwapCount;
    private List<string> _lastSwapEvents = new();

    private Dictionary<int, string> _slotAnimMap = new();

    private string _keyInput   = string.Empty;
    private string _valInput   = string.Empty;
    private string _status     = string.Empty;
    private string _statusCls  = string.Empty;
    private string _statusIcon = string.Empty;
    private string _result     = "—";

    private readonly List<LogEntry> _log = new();
    private struct LogEntry { public string Text; public string Cls; }

    private const int StepMs = 280;

    // ── Computed ──────────────────────────────────────────────────────────────
    private double LoadFactor => _table.Length > 0 ? (double)_count / _table.Length : 0;

    private int MaxPsl => _table
        .Where(s => s.State == RhSlotState.Occupied)
        .Select(s => s.Psl)
        .DefaultIfEmpty(0)
        .Max();

    private double AvgPsl
    {
        get
        {
            var occupied = _table.Where(s => s.State == RhSlotState.Occupied).ToList();
            return occupied.Count == 0 ? 0.0 : occupied.Average(s => s.Psl);
        }
    }

    private string LoadBarStyle
    {
        get
        {
            double pct = Math.Min(LoadFactor * 100.0, 100.0);
            return $"width:{pct:F0}%";
        }
    }
    private string LoadBarWarnCls => LoadFactor switch
    {
        > 0.85 => "lp-load-crit",
        > 0.65 => "lp-load-warn",
        _      => ""
    };

    private Dictionary<int, int> GetPslDistribution()
    {
        var dist = new Dictionary<int, int>();
        foreach (var s in _table.Where(s => s.State == RhSlotState.Occupied))
        {
            if (!dist.ContainsKey(s.Psl)) dist[s.Psl] = 0;
            dist[s.Psl]++;
        }
        return dist;
    }

    private int ComputeCurrentPsl(string key)
    {
        int cap = _table.Length;
        int home = RhHash(key, cap);
        for (int i = 0; i < cap; i++)
        {
            int si = (home + i) % cap;
            var slot = _table[si];
            if (slot.State == RhSlotState.Empty) return -1;
            if (slot.State == RhSlotState.Occupied && slot.Key == key) return slot.Psl;
        }
        return -1;
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Dtr.InitAsync();
        InitTable(11);
        _wasmReady = true;
        StateHasChanged();
    }

    private void InitTable(int capacity)
    {
        _table = new RhSlot[capacity];
        for (int i = 0; i < capacity; i++)
            _table[i] = new RhSlot();
        _count = 0;
    }

    // ── Hash Function ─────────────────────────────────────────────────────────
    private static int RhHash(string key, int capacity)
    {
        uint hash = 5381;
        foreach (char c in key)
            hash = ((hash << 5) + hash) ^ (uint)c;
        return (int)(hash % (uint)capacity);
    }

    // ── Robin Hood Insert (no animation) ──────────────────────────────────────
    // Returns (insertedAt, swapEvents) or (-1, _) on failure.
    private (int insertedAt, List<string> swaps) RhInsert(string key, string value)
    {
        int cap   = _table.Length;
        int home  = RhHash(key, cap);
        var swaps = new List<string>();

        // Build the element to insert
        var toInsert = new RhSlot
        {
            State    = RhSlotState.Occupied,
            Key      = key,
            Value    = value,
            HomeSlot = home,
            Psl      = 0
        };

        for (int i = 0; i < cap; i++)
        {
            int si   = (home + i) % cap;
            var slot = _table[si];

            // Empty slot → place here
            if (slot.State == RhSlotState.Empty)
            {
                _table[si] = toInsert;
                _count++;
                return (si, swaps);
            }

            // Duplicate check
            if (slot.State == RhSlotState.Occupied && slot.Key == toInsert.Key)
                return (-2, swaps); // already exists

            // Robin Hood: steal from the "rich" (lower PSL)
            if (toInsert.Psl > slot.Psl)
            {
                swaps.Add($"[{si}] PSL_new={toInsert.Psl} > PSL_cur={slot.Psl} «{TruncStr(slot.Key,8)}» → steal!");
                // Swap
                var displaced = slot;
                _table[si] = toInsert;
                toInsert = displaced;
            }

            // Advance PSL for the element continuing the search
            toInsert.Psl++;
            // Update home tracking
            if (i == 0) home = RhHash(toInsert.Key, cap); // re-anchor for displaced
        }
        return (-1, swaps); // table full
    }

    // ── Robin Hood Delete (backward shift) ────────────────────────────────────
    // Backward shift: after removing an element, shift subsequent elements
    // that are not at their home slot one position back.
    private bool RhDelete(string key, out int removedAt)
    {
        int cap  = _table.Length;
        int home = RhHash(key, cap);
        removedAt = -1;

        // Find the element
        for (int i = 0; i < cap; i++)
        {
            int si   = (home + i) % cap;
            var slot = _table[si];
            if (slot.State == RhSlotState.Empty) return false;  // not found
            if (slot.State == RhSlotState.Occupied && slot.Psl < i) return false; // early exit
            if (slot.State == RhSlotState.Occupied && slot.Key == key)
            {
                removedAt = si;
                // Backward shift
                int cur = si;
                while (true)
                {
                    int next = (cur + 1) % cap;
                    var nextSlot = _table[next];
                    // Stop if next is empty or at its home (PSL=0)
                    if (nextSlot.State == RhSlotState.Empty || nextSlot.Psl == 0)
                    {
                        _table[cur] = new RhSlot(); // clear
                        break;
                    }
                    // Shift next → cur, decrement its PSL
                    _table[cur] = new RhSlot
                    {
                        State    = RhSlotState.Occupied,
                        Key      = nextSlot.Key,
                        Value    = nextSlot.Value,
                        HomeSlot = nextSlot.HomeSlot,
                        Psl      = nextSlot.Psl - 1
                    };
                    cur = next;
                }
                _count--;
                return true;
            }
        }
        return false;
    }

    // ── Probe path for lookup ─────────────────────────────────────────────────
    private List<int> BuildLookupPath(string key, out bool found)
    {
        int cap  = _table.Length;
        int home = RhHash(key, cap);
        var path = new List<int>();
        found = false;

        for (int i = 0; i < cap; i++)
        {
            int si   = (home + i) % cap;
            var slot = _table[si];
            path.Add(si);

            if (slot.State == RhSlotState.Empty) break;  // not present
            // Robin Hood early termination: if current PSL < i, key can't be here
            if (slot.Psl < i) break;
            if (slot.State == RhSlotState.Occupied && slot.Key == key)
            {
                found = true;
                break;
            }
        }
        return path;
    }

    // ── Resize ────────────────────────────────────────────────────────────────
    private void MaybeResize()
    {
        if (LoadFactor < 0.70) return;
        int newCap = NextPrime(_table.Length * 2 + 1);
        var old    = _table;
        InitTable(newCap);
        foreach (var s in old.Where(s => s.State == RhSlotState.Occupied))
            RhInsert(s.Key, s.Value);
        AddLog($"Rehash: ёмкость расширена до {newCap}", "log-op");
    }

    // ── Operations ────────────────────────────────────────────────────────────

    private async Task DoContains()
    {
        _busy = true; ClearAnim(); _lastSwapEvents.Clear();
        var key  = _keyInput.Trim();
        var path = BuildLookupPath(key, out bool found);

        await AnimateProbe(path, found, new HashSet<int>());

        SetStatus($"ContainsKey({key}) → {found}", found ? "status-ok" : "status-err", found ? "✓" : "✗");
        _result = found ? "true" : "false";
        AddLog($"ContainsKey({key}) → {found} ({path.Count} probe)", found ? "log-ok" : "log-miss");
        _busy = false; StateHasChanged();
    }

    private async Task DoGet()
    {
        _busy = true; ClearAnim(); _lastSwapEvents.Clear();
        var key  = _keyInput.Trim();
        var path = BuildLookupPath(key, out bool found);
        string val = found ? _table[path[^1]].Value : string.Empty;

        await AnimateProbe(path, found, new HashSet<int>());

        SetStatus(found ? $"TryGetValue({key}) → \"{val}\"" : $"TryGetValue({key}) → не найдено",
                  found ? "status-ok" : "status-err", found ? "✓" : "✗");
        _result = found ? $"\"{val}\"" : "не найдено";
        AddLog($"Get({key}) → {(found ? val : "∅")} ({path.Count} probe)", found ? "log-ok" : "log-miss");
        _busy = false; StateHasChanged();
    }

    private async Task DoAdd()
    {
        _busy = true; ClearAnim(); _lastSwapEvents.Clear();
        var key = _keyInput.Trim();
        var val = _valInput.Trim();

        // Check duplicate first
        var checkPath = BuildLookupPath(key, out bool exists);
        if (exists)
        {
            await AnimateProbe(checkPath, false, new HashSet<int>());
            SetStatus($"Add({key}) — ключ уже существует", "status-err", "✗");
            _result = "уже есть";
            AddLog($"Add({key}) → exists", "log-err");
        }
        else
        {
            var (insertedAt, swaps) = RhInsert(key, val);
            _lastSwapEvents = swaps;
            _lastSwapCount  = swaps.Count;
            if (insertedAt >= 0)
            {
                MaybeResize();
                // After potential resize find where key landed
                var verifyPath = BuildLookupPath(key, out bool v2);
                int landedAt   = v2 && verifyPath.Count > 0 ? verifyPath[^1] : insertedAt;
                var swapSet    = new HashSet<int>(); // visualize in probe trail
                await AnimateProbe(verifyPath, true, swapSet);
                SetStatus($"Add({key}, {val}) — вставлено. Свопов: {swaps.Count}", "status-ok", "✓");
                _result = $"добавлено [{landedAt}]";
                AddLog($"Add({key}) → ok, slot [{landedAt}], PSL={_table[landedAt].Psl}, swaps={swaps.Count}", "log-ok");
            }
            else if (insertedAt == -2)
            {
                SetStatus($"Add({key}) — дубликат обнаружен", "status-err", "✗");
                _result = "уже есть";
                AddLog($"Add({key}) → duplicate", "log-err");
            }
            else
            {
                SetStatus($"Add({key}) — таблица полна", "status-err", "✗");
                _result = "таблица полна";
                AddLog($"Add({key}) → full", "log-err");
            }
        }
        _busy = false; StateHasChanged();
    }

    private async Task DoInsertOrAssign()
    {
        _busy = true; ClearAnim(); _lastSwapEvents.Clear();
        var key = _keyInput.Trim();
        var val = _valInput.Trim();

        var checkPath = BuildLookupPath(key, out bool exists);
        if (exists)
        {
            _table[checkPath[^1]].Value = val;
            await AnimateProbe(checkPath, true, new HashSet<int>());
            SetStatus($"InsertOrAssign({key}, {val}) — обновлено", "status-ok", "✓");
            _result = "обновлено";
            AddLog($"InsertOrAssign({key}) → updated [{checkPath[^1]}]", "log-ok");
        }
        else
        {
            var (insertedAt, swaps) = RhInsert(key, val);
            _lastSwapEvents = swaps;
            _lastSwapCount  = swaps.Count;
            MaybeResize();
            var verifyPath = BuildLookupPath(key, out bool v2);
            int landedAt   = v2 && verifyPath.Count > 0 ? verifyPath[^1] : insertedAt;
            await AnimateProbe(verifyPath, true, new HashSet<int>());
            SetStatus($"InsertOrAssign({key}, {val}) — вставлено [{landedAt}]. Свопов: {swaps.Count}", "status-ok", "✓");
            _result = $"вставлено [{landedAt}]";
            AddLog($"InsertOrAssign({key}) → inserted [{landedAt}], swaps={swaps.Count}", "log-ok");
        }
        _busy = false; StateHasChanged();
    }

    private async Task DoRemove()
    {
        _busy = true; ClearAnim(); _lastSwapEvents.Clear();
        var key  = _keyInput.Trim();
        var path = BuildLookupPath(key, out bool found);

        if (found)
        {
            await AnimateProbe(path, true, new HashSet<int>());
            bool deleted = RhDelete(key, out int removedAt);
            if (deleted)
            {
                SetStatus($"Remove({key}) — удалено из [{removedAt}], backward shift выполнен", "status-ok", "✓");
                _result = $"удалено [{removedAt}]";
                AddLog($"Remove({key}) → ok, backward-shift от [{removedAt}]", "log-ok");
            }
        }
        else
        {
            await AnimateProbe(path, false, new HashSet<int>());
            SetStatus($"Remove({key}) — ключ не найден", "status-err", "✗");
            _result = "не найдено";
            AddLog($"Remove({key}) → miss", "log-miss");
        }
        _busy = false; StateHasChanged();
    }

    private async Task DoClear()
    {
        _busy = true; ClearAnim(); _lastSwapEvents.Clear();
        InitTable(_table.Length);
        _lastProbePath.Clear();
        _lastSwapCount  = 0;
        _lastProbeSteps = 0;
        SetStatus("Clear() — таблица очищена", "status-ok", "✓");
        _result = "—";
        AddLog("Clear()", "log-op");
        _busy = false; StateHasChanged();
    }

