    {
        _busy = true; ClearAnim(); _lastSwapEvents.Clear();
        InitTable(11);
        string[] pairs = {
            "apple",     "яблоко",
            "banana",    "банан",
            "cherry",    "вишня",
            "date",      "финик",
            "elderberry","бузина",
