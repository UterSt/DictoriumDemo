@page "/demo/chaining"
@inject DictoriumJsService Dtr
@inject NavigationManager Nav

<PageTitle>ChainingDictionary — Демо — Dictorium</PageTitle>

<div class="page-wrap">

    <div class="breadcrumb">
        <a href="">Обзор</a>
        <span class="bc-sep">›</span>
        <a href="">Хэш-таблицы</a>
        <span class="bc-sep">›</span>
        <span class="bc-now">ChainingDictionary [LIVE]</span>
    </div>

    <div class="struct-head-bar">
        <div class="struct-issue-num" style="color:var(--acc-g)">
            dtr::ChainingDictionary&lt;string, string&gt; — реальная библиотека Dictorium через WASM
        </div>
        <h1 class="struct-h1">Открытое хэширование</h1>
        <div class="struct-en">ChainingDictionary.h · O(1) ожидаемое · метод цепочек</div>
        <p class="struct-description">
            Каждый <strong>bucket</strong> хранит связный список элементов с одинаковым хэшем.
            Коллизии разрешаются добавлением в цепочку — таблица никогда не переполняется.
            Все вызовы идут через <code>dtr::ChainingDictionary</code>, скомпилированную в WebAssembly.
        </p>
        <div class="struct-tags">
            <span class="s-tag">ContainsKey O(1+α)</span>
            <span class="s-tag">Add O(1+α)</span>
            <span class="s-tag">Remove O(1+α)</span>
            <span class="s-tag">α = n/m коэфф. загрузки</span>
            @if (_wasmReady)
            {
                <span class="s-tag" style="color:var(--acc-g);border-color:var(--acc-g)">● WASM готов</span>
            }
            else
            {
                <span class="s-tag" style="color:var(--acc-r)">○ Загрузка WASM...</span>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_status))
    {
        <div class="demo-status @_statusCls">
            <strong>@_statusIcon</strong>&nbsp; @_status
        </div>
    }

    @if (!_wasmReady)
    {
        <div class="comp-hint">Загрузка WebAssembly модуля Dictorium...</div>
    }
    else
    {
        <div class="demo-layout">

            <!-- Controls -->
            <div class="demo-controls">
                <div class="ctrl-section">
                    <div class="ctrl-section-title">Ключ (Key)</div>
                    <input class="search-input" style="width:100%;"
                           @bind="_keyInput" @bind:event="oninput"
                           placeholder="apple"
                           disabled="@_busy" />
                    <div class="ctrl-section-title" style="margin-top:6px;">Значение (Value)</div>
                    <input class="search-input" style="width:100%;margin-bottom:0;"
                           @bind="_valInput" @bind:event="oninput"
                           placeholder="яблоко"
                           disabled="@_busy" />
                </div>

                <div class="ctrl-ops">
                    <div class="op-hint-row">
                    <button class="btn-op btn-search" @onclick="DoContains"
                            disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput))">
                        ▶ ContainsKey(key)
                    </button>
                    <span class="op-hint-icon @(_activeDemoTip=="contains"?"active":"")" @onclick='()=>ToggleDemoTip("contains")'>i</span>
                </div>
                    <div class="op-hint-row">
                    <button class="btn-op btn-search" @onclick="DoGet"
                            disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput))">
                        ▶ TryGetValue(key)
                    </button>
                    <span class="op-hint-icon @(_activeDemoTip=="get"?"active":"")" @onclick='()=>ToggleDemoTip("get")'>i</span>
                </div>
                    <div class="op-hint-row">
                    <button class="btn-op btn-add" @onclick="DoAdd"
                            disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput) || string.IsNullOrWhiteSpace(_valInput))">
                        + Add(key, value)
                    </button>
                    <span class="op-hint-icon @(_activeDemoTip=="add"?"active":"")" @onclick='()=>ToggleDemoTip("add")'>i</span>
                </div>
                    <div class="op-hint-row">
                    <button class="btn-op btn-add" @onclick="DoInsertOrAssign"
                            disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput) || string.IsNullOrWhiteSpace(_valInput))">
                        ± InsertOrAssign(key, value)
                    </button>
                    <span class="op-hint-icon @(_activeDemoTip=="ioa"?"active":"")" @onclick='()=>ToggleDemoTip("ioa")'>i</span>
                </div>
                    <div class="op-hint-row">
                    <button class="btn-op btn-remove" @onclick="DoRemove"
                            disabled="@(_busy || string.IsNullOrWhiteSpace(_keyInput))">
                        − Remove(key)
                    </button>
                    <span class="op-hint-icon @(_activeDemoTip=="remove"?"active":"")" @onclick='()=>ToggleDemoTip("remove")'>i</span>
                </div>
                    <div class="op-hint-row">
                    <button class="btn-op btn-clear" @onclick="DoClear" disabled="@_busy">
                        ⊘ Clear()
                    </button>
                    <span class="op-hint-icon @(_activeDemoTip=="clear"?"active":"")" @onclick='()=>ToggleDemoTip("clear")'>i</span>
                </div>
                </div>

                <DemoOpHints ActiveTip="@_activeDemoTip" OnToggle="@((id) => { _activeDemoTip = id; StateHasChanged(); })" />

                <div class="ctrl-info">
                    <div class="ctrl-info-row">
                        <span>Count()</span>
                        <span class="ctrl-info-val">@_count</span>
                    </div>
                    <div class="ctrl-info-row">
                        <span>Buckets</span>
                        <span class="ctrl-info-val">@_buckets.Count</span>
                    </div>
                    <div class="ctrl-info-row">
                        <span>Загрузка (α)</span>
                        <span class="ctrl-info-val">@LoadFactor</span>
                    </div>
                    <div class="ctrl-info-row">
                        <span>Макс. цепочка</span>
                        <span class="ctrl-info-val">@MaxChainLen</span>
                    </div>
                    <div class="ctrl-info-row">
                        <span>Результат</span>
                        <span class="ctrl-info-val">@_result</span>
                    </div>
                </div>

                <div class="ctrl-legend">
                    <div class="legend-title">Легенда</div>
                    <div class="legend-row">
                        <span class="ch-legend-dot ch-dot-target"></span> Целевой bucket
                    </div>
                    <div class="legend-row">
                        <span class="ch-legend-dot ch-dot-found"></span> Найдено
                    </div>
                    <div class="legend-row">
                        <span class="ch-legend-dot ch-dot-miss"></span> Не найдено
                    </div>
                    <div class="legend-row">
                        <span class="ch-legend-dot ch-dot-empty"></span> Пустой bucket
                    </div>
                </div>

                <div class="ctrl-section">
                    <div class="ctrl-section-title">Быстрая загрузка</div>
                    <button class="btn-op" @onclick="LoadSample" disabled="@_busy" style="font-size:10px;">
                        ↓ Загрузить 8 пар (пример)
                    </button>
                </div>
            </div>

            <!-- Visualisation -->
            <div class="demo-main">

                <div class="viz-section">
                    <div class="viz-section-head">
                        <span class="viz-section-title">Хэш-таблица — метод цепочек</span>
                        <span class="viz-section-info">@_buckets.Count buckets · @_count элементов</span>
                    </div>

                    @if (_buckets.Count == 0)
                    {
                        <div class="ch-empty-state">
                            <div class="ch-empty-icon">⊞</div>
                            <div>Таблица пуста. Добавьте элементы — появятся buckets с цепочками.</div>
                        </div>
                    }
                    else
                    {
                        <div class="ch-table-wrap">
                            @foreach (var bucket in _buckets)
                            {
                                string bucketCls = GetBucketCls(bucket.Slot);
                                <div class="ch-bucket-row @bucketCls">
                                    <div class="ch-bucket-idx">
                                        [@bucket.Slot]
                                    </div>
                                    <div class="ch-bucket-arrow">
                                        @if (bucket.Chain.Count > 0)
                                        {
                                            <span>→</span>
                                        }
                                        else
                                        {
                                            <span class="ch-null">∅</span>
                                        }
                                    </div>
                                    <div class="ch-chain">
                                        @if (bucket.Chain.Count == 0)
                                        {
                                            <div class="ch-node-null">null</div>
                                        }
                                        else
                                        {
                                            @for (int ci = 0; ci < bucket.Chain.Count; ci++)
                                            {
                                                var citem = bucket.Chain[ci];
                                                bool isHit = citem.Key == _highlightKey && bucket.Slot == _highlightSlot;
                                                string nodeCls = isHit ? "ch-node ch-node-hit" : "ch-node";
                                                <div class="@nodeCls">
                                                    <span class="ch-node-key">@TruncStr(citem.Key, 10)</span>
                                                    <span class="ch-node-sep">→</span>
                                                    <span class="ch-node-val">@TruncStr(citem.Value, 10)</span>
                                                </div>
                                                @if (ci < bucket.Chain.Count - 1)
                                                {
                                                    <div class="ch-chain-link">↔</div>
                                                }
                                            }
                                        }
                                    </div>
                                    @if (bucket.Chain.Count > 0)
                                    {
                                        <div class="ch-chain-len">×@bucket.Chain.Count</div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="ch-stats-bar">
                            <div class="ch-stat-item">
                                <span class="ch-stat-label">Коэффициент загрузки α = n/m</span>
                                <div class="ch-load-bar-wrap">
                                    <div class="ch-load-bar" style="@LoadBarStyle"></div>
                                    <span class="ch-load-val">@LoadFactor</span>
                                </div>
                            </div>
                            <div class="ch-stat-item">
                                <span class="ch-stat-label">Распределение по цепочкам</span>
                                <div class="ch-dist-bars">
                                    @foreach (var db in _buckets)
                                    {
                                        int pct = MaxChainLen > 0 ? (int)((double)db.Chain.Count / MaxChainLen * 100) : 0;
                                        string distCls = db.Slot == _highlightSlot
                                            ? "ch-dist-bar ch-dist-bar-active"
                                            : "ch-dist-bar";
                                        <div class="ch-dist-col">
                                            <div class="@distCls" style="@("height:" + pct + "%")"></div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="viz-section" style="margin-top:8px;">
                    <div class="viz-section-head">
                        <span class="viz-section-title">Лог операций</span>
                        <button class="btn-op btn-clear"
                                style="padding:1px 6px;font-size:10px;width:auto;"
                                @onclick="ClearLog">
                            очистить
                        </button>
                    </div>
                    <div class="demo-log">
                        @if (_log.Count == 0)
                        {
                            <div class="log-line log-miss">// нет операций</div>
                        }
                        else
                        {
                            @for (int li = _log.Count - 1; li >= 0; li--)
                            {
                                <div class="log-line @_log[li].Cls">@_log[li].Text</div>
                            }
                        }
                    </div>
                </div>

            </div>
        </div>
    }
</div>

@code {
    // ── Demo tip state ──────────────────────────────────────────────────────
    private string? _activeDemoTip = null;
    private void ToggleDemoTip(string id) => _activeDemoTip = _activeDemoTip == id ? null : id;

    // ── State ────────────────────────────────────────────────────────────
    private bool   _wasmReady;
    private bool   _busy;
    private int    _handle = -1;
    private int    _count;

    private string _keyInput   = string.Empty;
    private string _valInput   = string.Empty;
    private string _status     = string.Empty;
    private string _statusCls  = string.Empty;
    private string _statusIcon = string.Empty;
    private string _result     = "—";

    private List<ChainBucket> _buckets = new();
    private int    _highlightSlot = -1;
    private string _highlightKey  = string.Empty;

    private readonly List<LogEntry> _log = new();

    private struct LogEntry
    {
        public string Text;
        public string Cls;
    }

    // ── Computed ─────────────────────────────────────────────────────────
    private string LoadFactor
    {
        get
        {
            if (_buckets.Count == 0) return "0.00";
            return ((double)_count / _buckets.Count).ToString("F2");
        }
    }

    private string LoadBarStyle
    {
        get
        {
            if (_buckets.Count == 0) return "width:0%";
            double pct = Math.Min((double)_count / _buckets.Count * 50.0, 100.0);
            return "width:" + pct.ToString("F0") + "%";
        }
    }

    private int MaxChainLen =>
        _buckets.Count > 0 ? _buckets.Max(b => b.Chain.Count) : 0;

    // ── Lifecycle ────────────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Dtr.InitAsync();
        _handle = await Dtr.ChainingCreateAsync();
        _wasmReady = true;
        StateHasChanged();
    }

    // ── Operations ───────────────────────────────────────────────────────
    private async Task DoContains()
    {
        _busy = true;
        ClearHighlight();
        bool found = await Dtr.ChainingContainsAsync(_handle, _keyInput);
        await RefreshSnapshot(_keyInput);
        SetStatus(
            "ContainsKey(" + _keyInput + ") → " + found,
            found ? "status-ok" : "status-err",
            found ? "✓" : "✗");
        _result = found ? "true" : "false";
        AddLog("ContainsKey(" + _keyInput + ") → " + found, found ? "log-ok" : "log-miss");
        _busy = false;
        StateHasChanged();
    }

    private async Task DoGet()
    {
        _busy = true;
        ClearHighlight();
        string val = await Dtr.ChainingGetAsync(_handle, _keyInput);
        await RefreshSnapshot(_keyInput);
        bool found = !string.IsNullOrEmpty(val);
        SetStatus(
            found ? "TryGetValue(" + _keyInput + ") → " + val
                  : "TryGetValue(" + _keyInput + ") → не найдено",
            found ? "status-ok" : "status-err",
            found ? "✓" : "✗");
        _result = found ? val : "не найдено";
        AddLog("Get(" + _keyInput + ") → " + (found ? val : "∅"), found ? "log-ok" : "log-miss");
        _busy = false;
        StateHasChanged();
    }

    private async Task DoAdd()
    {
        _busy = true;
        ClearHighlight();
        bool ok = await Dtr.ChainingAddAsync(_handle, _keyInput, _valInput);
        _count = await Dtr.ChainingCountAsync(_handle);
        await RefreshSnapshot(_keyInput);
        if (ok) _highlightKey = _keyInput;
        SetStatus(
            ok ? "Add(" + _keyInput + ", " + _valInput + ") — успешно"
               : "Add(" + _keyInput + ") — ключ уже существует",
            ok ? "status-ok" : "status-err",
            ok ? "✓" : "✗");
        _result = ok ? "добавлено" : "уже есть";
        AddLog("Add(" + _keyInput + ") → " + (ok ? "ok" : "exists"), ok ? "log-ok" : "log-err");
        _busy = false;
        StateHasChanged();
    }

    private async Task DoInsertOrAssign()
    {
        _busy = true;
        ClearHighlight();
        await Dtr.ChainingInsertOrAssignAsync(_handle, _keyInput, _valInput);
        _count = await Dtr.ChainingCountAsync(_handle);
        await RefreshSnapshot(_keyInput);
        _highlightKey = _keyInput;
        SetStatus(
            "InsertOrAssign(" + _keyInput + ", " + _valInput + ") — выполнено",
            "status-ok", "✓");
        _result = "ok";
        AddLog("InsertOrAssign(" + _keyInput + ")", "log-ok");
        _busy = false;
        StateHasChanged();
    }

    private async Task DoRemove()
    {
        _busy = true;
        ClearHighlight();
        bool ok = await Dtr.ChainingRemoveAsync(_handle, _keyInput);
        _count = await Dtr.ChainingCountAsync(_handle);
        await RefreshSnapshot();
        SetStatus(
            ok ? "Remove(" + _keyInput + ") — удалено"
               : "Remove(" + _keyInput + ") — ключ не найден",
            ok ? "status-ok" : "status-err",
            ok ? "✓" : "✗");
        _result = ok ? "удалено" : "не найдено";
        AddLog("Remove(" + _keyInput + ") → " + (ok ? "ok" : "miss"), ok ? "log-ok" : "log-miss");
        _busy = false;
        StateHasChanged();
    }

    private async Task DoClear()
    {
        _busy = true;
        ClearHighlight();
        await Dtr.ChainingClearAsync(_handle);
        _count = 0;
        _buckets.Clear();
        SetStatus("Clear() — таблица очищена", "status-ok", "✓");
        _result = "—";
        AddLog("Clear()", "log-op");
        _busy = false;
        StateHasChanged();
    }

    private async Task LoadSample()
    {
        _busy = true;
        ClearHighlight();
        string[] pairs =
        {
            "apple",      "яблоко",
            "banana",     "банан",
            "cherry",     "вишня",
            "date",       "финик",
            "elderberry", "бузина",
            "fig",        "инжир",
            "grape",      "виноград",
            "hazel",      "лещина"
        };
        for (int i = 0; i < pairs.Length; i += 2)
            await Dtr.ChainingAddAsync(_handle, pairs[i], pairs[i + 1]);
        _count = await Dtr.ChainingCountAsync(_handle);
        await RefreshSnapshot();
        SetStatus("Загружено " + _count + " пар", "status-ok", "✓");
        AddLog("Sample: загружено " + _count + " пар", "log-ok");
        _busy = false;
        StateHasChanged();
    }

    private void ClearLog() => _log.Clear();

    // ── Helpers ──────────────────────────────────────────────────────────
    private async Task RefreshSnapshot(string? lookupKey = null)
    {
        _buckets = await Dtr.ChainingSnapshotAsync(_handle);
        if (lookupKey != null)
            _highlightSlot = FindBucketForKey(lookupKey);
    }

    private int FindBucketForKey(string key)
    {
        foreach (var b in _buckets)
            if (b.Chain.Any(item => item.Key == key))
                return b.Slot;
        return -1;
    }

    private string GetBucketCls(int slot)
    {
        if (slot != _highlightSlot) return string.Empty;
        if (!string.IsNullOrEmpty(_highlightKey))
        {
            var bucket = _buckets.FirstOrDefault(b => b.Slot == slot);
            if (bucket != null && bucket.Chain.Any(item => item.Key == _highlightKey))
                return "ch-bucket-hit";
        }
        return "ch-bucket-target";
    }

    private void ClearHighlight()
    {
        _highlightSlot = -1;
        _highlightKey  = string.Empty;
    }

    private void SetStatus(string msg, string cls, string icon)
    {
        _status     = msg;
        _statusCls  = cls;
        _statusIcon = icon;
    }

    private void AddLog(string text, string cls)
    {
        _log.Add(new LogEntry { Text = text, Cls = cls });
        if (_log.Count > 50) _log.RemoveAt(0);
    }

    private static string TruncStr(string s, int max) =>
        s.Length <= max ? s : s[..max] + "…";
}
